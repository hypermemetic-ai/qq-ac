)
MUTATING_TOOL_NAMES = ("edit", "write")
COMMIT_SHAPED_COMMAND_IDIOMS = (
    re.compile(
        r'(?:^|[;&|"]\s*)git(?:\s+[^;&|\s]+){0,12}\s+commit\b',
        re.IGNORECASE,
    ),
)
CHECK_SHAPED_COMMAND_IDIOMS = (
    re.compile(r"tests/", re.IGNORECASE),
    re.compile(r"\bratchet\b", re.IGNORECASE),
    re.compile(r"\bshell-tests\b", re.IGNORECASE),
    re.compile(r"\bgh\s+pr\s+checks\b", re.IGNORECASE),
)
COMPLETION_CLAIM_IDIOMS = re.compile(
    r"\b(?:checks?\s+pass(?:ed)?|green|ready\s+to\s+merge|"
    r"all\s+tests?\s+pass(?:ed)?|done\s+and\s+verified)\b",
    re.IGNORECASE,
)
ANALYSIS_KINDS = {
    "tool-gap.capability-unknown", "tool-gap.tool-missing", "instruction-conflict",
    "instruction-deficiency", "tool-misuse", "friction", "waste", "failure",
    "substrate", "design-question", "operator-seam.unconfirmed-assumption",
    "operator-seam.unseen-request", "operator-seam.misread-direction",
    "operator-seam.misleading-claim", "operator-seam.stale-world",
    "operator-seam.cross-session", "operator-seam.abandonment",
}
ANALYSIS_ROOT_CAUSE_LOCATIONS = {
    "work-order", "skill", "instruction", "tool", "agent-behavior", "substrate",
    "harness-design",
}
ANALYSIS_CONFIDENCE = {"high": 3, "medium": 2, "low": 1}
# Sane-session bound: rejects absurd magnitudes before cost arithmetic.
SANE_SESSION_BOUND = 10 ** 15
SPAN_FIELDS = {
    "schema_version", "trace_id", "span_id", "parent_span_id", "root_span_id",
    "name", "phase", "actor", "start_time", "end_time", "duration_ms",
    "status", "source", "attributes",
}

analysis_validation_mode = False


def analysis_failed(message):
    print(json.dumps({
        "schema": "qq-observer.analysis",
        "schema_version": 1,
        "status": "analysis_failed",
        "reason": str(message),
    }, separators=(",", ":"), sort_keys=True))
    raise SystemExit(1)


def fail(message):
    if analysis_validation_mode:
        analysis_failed(message)
    print(f"qq-observe: {message}", file=sys.stderr)
    raise SystemExit(64)

def timestamp(value):
    try:
        parsed = dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        fail(f"invalid timestamp: {value}")
    if parsed.tzinfo is None:
        fail(f"timestamp requires a timezone: {value}")
    return parsed

def new_id(chars):
    return os.urandom(chars // 2).hex()

def parse_summary_options(values):
    options = {"json": False}
    while values:
        flag = values.pop(0)
        if flag == "--json":
            options["json"] = True
        elif flag in {"--since", "--until"} and values:
            options[flag[2:]] = values.pop(0)
        else:
            fail(f"invalid or incomplete option: {flag}")
    return options

def parse_options(values, session=False):
    options = {"attributes": {}}
    if session:
        if not values or values[0].startswith("--"):
            fail("read-session requires a session JSONL path")
        options["session"] = values.pop(0)
    valued = {"--name", "--actor", "--start", "--end", "--phase", "--status",
              "--source", "--trace-id", "--span-id", "--parent-span-id", "--root-span-id"}
    while values:
        flag = values.pop(0)
        if flag not in valued | {"--attribute"} or not values:
            fail(f"invalid or incomplete option: {flag}")
        value = values.pop(0)
        if flag == "--attribute":
            if "=" not in value or not value.split("=", 1)[0]:
                fail("attributes must be KEY=VALUE")
            key, item = value.split("=", 1)
            options["attributes"][key] = item
        else:
            options[flag[2:].replace("-", "_")] = value
    return options

def context(options):
    trace_id = options.get("trace_id") or os.environ.get("QQ_TRACE_ID") or new_id(32)
    span_id = options.get("span_id") or new_id(16)
    parent = options.get("parent_span_id") or os.environ.get("PI_PARENT_SPAN_ID") or None
    root = options.get("root_span_id") or os.environ.get("PI_ROOT_SPAN_ID") or parent or span_id
    if not HEX32.fullmatch(trace_id): fail("trace ID must be 32 lowercase hex characters")
    for label, value in (("span ID", span_id), ("parent span ID", parent), ("root span ID", root)):
        if value is not None and not HEX16.fullmatch(value):
            fail(f"{label} must be 16 lowercase hex characters")
    return trace_id, span_id, parent, root

def append(record):
    try:
        existing = os.lstat(store_file)
    except FileNotFoundError:
        existing = None
    except OSError as error:
        fail(f"cannot inspect span store leaf: {error}")
    if existing is not None and not stat.S_ISREG(existing.st_mode):
        fail("span store leaf is not a regular file")
    line = json.dumps(record, separators=(",", ":"), sort_keys=True)
    flags = os.O_WRONLY | os.O_CREAT | os.O_APPEND | os.O_NONBLOCK
    flags |= getattr(os, "O_NOFOLLOW", 0)
    try:
        directory = os.open(os.path.dirname(store_file), os.O_RDONLY | os.O_DIRECTORY)
        if os.path.realpath(f"/proc/self/fd/{directory}") != os.path.dirname(store_file):
            fail("span store directory changed during open")
        fd = os.open(os.path.basename(store_file), flags, 0o600, dir_fd=directory)
        os.close(directory)
    except OSError as error:
        fail(f"cannot open span store leaf: {error}")
    try:
        if not stat.S_ISREG(os.fstat(fd).st_mode):
            fail("span store leaf is not a regular file")
        os.write(fd, (line + "\n").encode())
    finally:
        os.close(fd)

def read_store():
    try:
        existing = os.lstat(store_file)
    except FileNotFoundError:
        return
    except OSError as error:
        fail(f"cannot inspect span store leaf: {error}")
    if not stat.S_ISREG(existing.st_mode):
        fail("span store leaf is not a regular file")
    flags = os.O_RDONLY | os.O_NONBLOCK | getattr(os, "O_NOFOLLOW", 0)
    try:
        directory = os.open(os.path.dirname(store_file), os.O_RDONLY | os.O_DIRECTORY)
        try:
            if os.path.realpath(f"/proc/self/fd/{directory}") != os.path.dirname(store_file):
                fail("span store directory changed during open")
            fd = os.open(os.path.basename(store_file), flags, dir_fd=directory)
        finally:
            os.close(directory)
    except OSError as error:
        fail(f"cannot open span store leaf: {error}")
    try:
        if not stat.S_ISREG(os.fstat(fd).st_mode):
            fail("span store leaf is not a regular file")
        with os.fdopen(fd, "rb") as source:
            fd = None
            yield from source
    except OSError as error:
        fail(f"cannot read span store: {error}")
    finally:
        if fd is not None:
            os.close(fd)

def summary_span(line):
    try:
        item = json.loads(line.decode("utf-8"))
    except (UnicodeDecodeError, ValueError, RecursionError):
        return None
    if not isinstance(item, dict) or not SPAN_FIELDS <= item.keys():
        return None
    try:
        start = dt.datetime.fromisoformat(item["start_time"].replace("Z", "+00:00"))
        end = dt.datetime.fromisoformat(item["end_time"].replace("Z", "+00:00"))
    except (AttributeError, ValueError):
        return None
    duration = item.get("duration_ms")
    phase = item.get("phase")
    if isinstance(duration, bool) or not isinstance(duration, (int, float)):
        return None
    try:
        duration = float(duration)
    except OverflowError:
        return None
    if (
        start.tzinfo is None
        or end.tzinfo is None
        or isinstance(item["schema_version"], bool)
        or item["schema_version"] != 1
        or not isinstance(item["trace_id"], str)
        or not HEX32.fullmatch(item["trace_id"])
        or not isinstance(item["span_id"], str)
        or not HEX16.fullmatch(item["span_id"])
        or (item["parent_span_id"] is not None and (
            not isinstance(item["parent_span_id"], str) or not HEX16.fullmatch(item["parent_span_id"])
        ))
        or not isinstance(item["root_span_id"], str)
        or not HEX16.fullmatch(item["root_span_id"])
        or not isinstance(item["name"], str)
        or not isinstance(item["actor"], str)
        or (phase is not None and (not isinstance(phase, str) or phase not in PHASES))
        or not math.isfinite(duration)
        or duration < 0
        or not isinstance(item["status"], str)
        or not isinstance(item["source"], str)
        or not isinstance(item["attributes"], dict)
    ):
        return None
    # schema v1 derives duration_ms from start/end (see emit()): reject
    # impossible ordering, and durations exceeding the span's own wall time
    # beyond slack, so adversarial or corrupt lines cannot poison aggregates.
    # Understated durations (active-time spans) remain admissible.
    if end < start or duration > (end - start).total_seconds() * 1000 + 1000:
        return None
    item["duration_ms"] = duration
    return item, start

def resolved_span_status(item):
    detail = {
        "trace_id": item["trace_id"],
        "span_id": item["span_id"],
        "name": item["name"],
        "raw_status": item["status"],
        "status": item["status"],
    }
    attributes = item["attributes"]
    exit_status = attributes.get("exit.status")
    if (
        item["source"] != "qq-dispatch"
        or exit_status not in ("143", "130", "129")
        or "run.id" not in attributes
        or attributes["run.id"] == "manual"
    ):
        return detail

    detail["status"] = "error"
    detail["outcome"] = {"resolved": "unresolved", "note": "teardown-signal"}
    run_id = attributes["run.id"]
    if (
        not isinstance(run_id, str)
        or not run_id
        or run_id in (".", "..")
        or os.path.basename(run_id) != run_id
    ):
        return detail

    if "QQ_DISPATCH_RUNTIME_ROOT" in os.environ:
        runtime_root = Path(os.environ["QQ_DISPATCH_RUNTIME_ROOT"])
    else:
        runtime_root = Path(os.environ.get("TMPDIR") or "/tmp") / f"pi-subagents-uid-{os.getuid()}"
    status_path = runtime_root / "async-subagent-runs" / run_id / "status.json"
    fd = None
    try:
        existing = os.lstat(status_path)
        if not stat.S_ISREG(existing.st_mode):
            return detail
        flags = os.O_RDONLY | os.O_NONBLOCK | getattr(os, "O_NOFOLLOW", 0)
        fd = os.open(status_path, flags)
        if not stat.S_ISREG(os.fstat(fd).st_mode):
            return detail
        with os.fdopen(fd, "rb") as source:
            fd = None
            payload = source.read(STATUS_JSON_CAP + 1)
            if len(payload) > STATUS_JSON_CAP:
                return detail
            record = json.loads(payload.decode("utf-8"))
    except (OSError, ValueError, UnicodeError, RecursionError):
        return detail
    finally:
        if fd is not None:
            os.close(fd)

    if not isinstance(record, dict):
        return detail
    state = record.get("state")
    status = {"complete": "ok", "failed": "error", "stopped": "error"}.get(state) if isinstance(state, str) else None
    if status:
        detail["status"] = status
        detail["outcome"]["resolved"] = state
    return detail

def rounded(value):
    return float(f"{value:.1f}")

def aggregate_summary(options):
    since = timestamp(options["since"]) if "since" in options else None
    until = timestamp(options["until"]) if "until" in options else None
    if since is not None and until is not None and since > until:
        fail("since timestamp follows until timestamp")
    span_count = skipped = 0
    traces = set()
    phase_durations = {}
    recurrence_stats = {}
    status_counts = {}
    span_statuses = []
    for line in read_store():
        parsed = summary_span(line)
        if parsed is None:
            skipped += 1
            continue
        item, start = parsed
        if (since is not None and start < since) or (until is not None and start > until):
            continue
        span_count += 1
        traces.add(item["trace_id"])
        phase_durations.setdefault(item["phase"], []).append(item["duration_ms"])
        recurrence = recurrence_stats.setdefault((item["name"], item["actor"]), [0, 0.0])
        recurrence[0] += 1
        recurrence[1] += item["duration_ms"]
        status_detail = resolved_span_status(item)
        span_statuses.append(status_detail)
        status = status_detail["status"]
        if status != "ok":
            status_counts[status] = status_counts.get(status, 0) + 1

    phases = []
    for phase, durations in phase_durations.items():
        ordered = sorted(durations)
        total = sum(durations)
        phases.append({
            "phase": phase,
            "spans": len(durations),
            "total_ms": rounded(total),
            "mean_ms": rounded(total / len(durations)),
            "p50_ms": rounded(ordered[math.ceil(0.50 * len(ordered)) - 1]),
            "p95_ms": rounded(ordered[math.ceil(0.95 * len(ordered)) - 1]),
        })
    phases.sort(key=lambda row: (
        -sum(phase_durations[row["phase"]]),
        "(none)" if row["phase"] is None else row["phase"],
    ))

    recurrence = [{
        "name": name,
        "actor": actor,
        "runs": runs,
        "total_ms": rounded(total),
        "mean_ms": rounded(total / runs),
    } for (name, actor), (runs, total) in recurrence_stats.items()]
    recurrence.sort(key=lambda row: (
        -recurrence_stats[(row["name"], row["actor"])][1], row["name"], row["actor"],
    ))
    recurrence = recurrence[:20]
    statuses = [
        {"status": status, "count": count}
        for status, count in sorted(status_counts.items(), key=lambda item: (-item[1], item[0]))
    ]
    return {
        "window": {"since": options.get("since"), "until": options.get("until")},
        "spans": span_count,
        "traces": len(traces),
        "skipped": skipped,
        "phases": phases,
        "recurrence": recurrence,
        "statuses": statuses,
        "span_statuses": span_statuses,
    }

def print_summary(summary):
    window = summary["window"]
    if window["since"] is None and window["until"] is None:
        print("Window: all")
    else:
        print(f"Window: [{window['since'] or '(open)'}, {window['until'] or '(open)'}]")
    print(f"Spans: {summary['spans']}")
    print(f"Traces: {summary['traces']}")
    print(f"Malformed lines skipped: {summary['skipped']}")
    if not summary["spans"]:
        return

    print("\nPhase latencies")
    print("PHASE            SPANS  TOTAL_MS  MEAN_MS   P50_MS   P95_MS")
    for row in summary["phases"]:
        label = "(none)" if row["phase"] is None else row["phase"]
        print(f"{label:<16} {row['spans']:>5d} {row['total_ms']:>9.1f} "
              f"{row['mean_ms']:>8.1f} {row['p50_ms']:>8.1f} {row['p95_ms']:>8.1f}")

    print("\nSpan recurrence")
    name_width = max(len("NAME"), *(len(row["name"]) for row in summary["recurrence"]))
    actor_width = max(len("ACTOR"), *(len(row["actor"]) for row in summary["recurrence"]))
    print(f"{'NAME':<{name_width}}  {'ACTOR':<{actor_width}}  RUNS  TOTAL_MS  MEAN_MS")
    for row in summary["recurrence"]:
        print(f"{row['name']:<{name_width}}  {row['actor']:<{actor_width}}  {row['runs']:>4d} "
              f"{row['total_ms']:>9.1f} {row['mean_ms']:>8.1f}")

    if summary["statuses"]:
        print("\nNon-ok statuses")
        status_width = max(len("STATUS"), *(len(row["status"]) for row in summary["statuses"]))
        print(f"{'STATUS':<{status_width}} COUNT")
        for row in summary["statuses"]:
            print(f"{row['status']:<{status_width}} {row['count']:>5d}")

OBSERVE_BLOCKS = ("text", "thinking", "toolCall", "toolResult")
TOKEN_FIELDS = ("input", "output", "cache_read", "cache_write")
CORRECTION = re.compile(
    r"(?:^\s*(?:no\b|actually\b|correction\b|instead\b|stop\b)"
    r"|\b(?:that's|that is)\s+(?:not|wrong)\b"
    r"|\byou\s+(?:misunderstood|missed|ignored)\b"
    r"|\bi\s+(?:said|asked|meant)\b"
    r"|\b(?:do not|don't)\s+do that\b)",
    re.IGNORECASE,
)
SIGNAL_WINDOW = 10
PI_CONTROL_ENTRIES = {
    "session", "model_change", "thinking_level_change", "custom_message",
    "custom", "session_info",
}


def session_jsonl(path, legacy=False):
    """Read once; facts/signals accept BOM, while legacy preserves read-session's Pi contract."""
    entries = []
    observed = []
    header_seen = False
    try:
        with path.open("rb") as source:
            for number, raw in enumerate(source, 1):
                if not raw.strip():
                    if legacy:
                        continue
                    fail(f"malformed JSON at line {number}: blank line")
                if legacy:
                    item = json.loads(raw.decode("utf-8"))
                    if not header_seen:
                        if not isinstance(item, dict) or item.get("type") != "session" or item.get("version") != 3:
                            fail("session JSONL must begin with a type=session, version=3 header")
                        header_seen = True
                    if not isinstance(item, dict) or not isinstance(item.get("timestamp"), str):
                        fail(f"session entry {number} lacks a timestamp")
                    observed.append(timestamp(item["timestamp"]))
                    entries.append({"line": number, "item": item})
                    continue
                try:
                    item = json.loads(raw, parse_constant=int)
                except (UnicodeDecodeError, ValueError, RecursionError) as error:
                    detail = error.msg if isinstance(error, json.JSONDecodeError) else str(error)
                    fail(f"malformed JSON at line {number}: {detail}")
                parsed_time = None
                if isinstance(item, dict) and isinstance(item.get("timestamp"), str):
                    value = item["timestamp"]
                    try:
                        parsed_time = dt.datetime.fromisoformat(value.replace("Z", "+00:00"))
                    except ValueError:
                        fail(f"invalid timestamp at line {number}: {value}")
                    if parsed_time.tzinfo is None:
                        fail(f"timestamp requires a timezone at line {number}: {value}")
                    observed.append(parsed_time)
                entries.append({"line": number, "item": item, "time": parsed_time})
    except (OSError, json.JSONDecodeError, UnicodeDecodeError) as error:
        if legacy:
            fail(f"cannot read session JSONL: {error}")
        fail(f"cannot read session JSONL: {error}")

    if legacy:
        if not observed:
            fail("session JSONL has no timestamped entries")
        return entries, observed
    if not entries:
        fail("session JSONL has no entries")
    first = entries[0]["item"]
    if not isinstance(first, dict) or first.get("type") != "session":
        fail("cannot auto-detect session format from line 1")
    if first.get("version") != 3:
        fail("session JSONL must begin with a type=session, version=3 header")
    if not observed:
        fail("session JSONL has no timestamped entries")
    return entries, observed


def new_session_analysis(entries, observed):
    return {
        "format": "pi",
        "entries": entries,
        "observed": observed,
        "turns": Counter(),
        "blocks": Counter({name: 0 for name in OBSERVE_BLOCKS}),
        "token_totals": {name: 0 for name in TOKEN_FIELDS},
        "token_present": Counter(),
        "token_unavailable": Counter({name: 0 for name in TOKEN_FIELDS}),
        "usage_records": 0,
        "calls": [],
        "results": [],
        "users": [],
        "assistant_texts": [],
        "assistant_reasoning": [],
        "message_roles": [],
        "compactions": [],
        "unknown": {},
    }


def entry_type(item):
    if not isinstance(item, dict):
        return f"<{type(item).__name__}>"
    value = item.get("type")
    return value if isinstance(value, str) else "<missing-type>"


def mark_unknown(analysis, line, shape):
    analysis["unknown"].setdefault(line, shape)


def numeric_token(value):
    if isinstance(value, bool) or not isinstance(value, (int, float)) or value < 0:
        return False
    try:
        return math.isfinite(value)
    except OverflowError:
        return False


def add_usage(analysis, record, names):
    analysis["usage_records"] += 1
    for field in TOKEN_FIELDS:
        value = record.get(names[field]) if isinstance(record, dict) else None
        candidate = analysis["token_totals"][field] + value if numeric_token(value) else None
        if numeric_token(value) and numeric_token(candidate):
            analysis["token_totals"][field] = candidate
            analysis["token_present"][field] += 1
        else:
            analysis["token_unavailable"][field] += 1


def content_text(content):
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    return "\n".join(
        block.get("text", "")
        for block in content
        if isinstance(block, dict)
        and block.get("type") == "text"
        and isinstance(block.get("text"), str)
    )


def canonical_arguments(value):
    if isinstance(value, str):
        try:
            value = json.loads(value)
        except (ValueError, RecursionError):
            return value
    try:
        return json.dumps(value, separators=(",", ":"), sort_keys=True)
    except (TypeError, ValueError, RecursionError):
        return repr(value)


def add_call(analysis, line, payload, name, arguments, call_id):
    if not isinstance(name, str) or not name:
        name = "(unknown)"
        mark_unknown(analysis, line, f"{analysis['format']}:toolCall:missing-name")
    analysis["blocks"]["toolCall"] += 1
    analysis["calls"].append({
        "line": line,
        "name": name,
        "arguments": canonical_arguments(arguments),
        "id": call_id if isinstance(call_id, str) else None,
        "payload": payload,
    })


def parse_pi(analysis):
    usage_names = {
        "input": "input", "output": "output",
        "cache_read": "cacheRead", "cache_write": "cacheWrite",
    }
    for entry in analysis["entries"]:
        line, item = entry["line"], entry["item"]
        if not isinstance(item, dict):
            mark_unknown(analysis, line, f"pi:{entry_type(item)}")
            continue
        kind = item.get("type")
        if not isinstance(kind, str):
            mark_unknown(analysis, line, "pi:<missing-type>")
            continue
        if kind == "compaction":
            analysis["compactions"].append(line)
            continue
        if kind in PI_CONTROL_ENTRIES:
            continue
        if kind != "message" or not isinstance(item.get("message"), dict):
            mark_unknown(analysis, line, f"pi:{entry_type(item)}")
            continue
        message = item["message"]
        role = message.get("role")
        if not isinstance(role, str) or not role:
            mark_unknown(analysis, line, "pi:message:missing-role")
            continue
        analysis["turns"][role] += 1
        analysis["message_roles"].append((line, role))
        content = message.get("content")
        if role == "user":
            analysis["users"].append((line, content_text(content)))
        if role == "assistant":
            add_usage(analysis, message.get("usage"), usage_names)
            analysis["assistant_texts"].append((line, content_text(content)))
        if role == "toolResult":
            analysis["blocks"]["toolResult"] += 1
            call_id = message.get("toolCallId")
            name = message.get("toolName")
            analysis["results"].append({
                "line": line,
                "name": name if isinstance(name, str) else None,
                "id": call_id if isinstance(call_id, str) else None,
                "error": message.get("isError") is True,
            })
        reasoning_chars = 0
        if isinstance(content, str):
            analysis["blocks"]["text"] += 1
        elif isinstance(content, list):
            for block in content:
                if not isinstance(block, dict):
                    mark_unknown(analysis, line, "pi:message:block:<non-object>")
                    continue
                block_type = block.get("type")
                if block_type == "text":
                    analysis["blocks"]["text"] += 1
                elif block_type == "thinking":
                    analysis["blocks"]["thinking"] += 1
                    thinking = block.get("thinking")
                    if isinstance(thinking, str):
                        reasoning_chars += len(thinking)
                elif block_type == "toolCall":
                    add_call(
                        analysis, line, block, block.get("name"),
                        block.get("arguments"), block.get("id"),
                    )
                elif block_type != "image":
                    mark_unknown(analysis, line, f"pi:message:block:{block_type or '<missing-type>'}")
        elif content is not None:
            mark_unknown(analysis, line, f"pi:message:content:<{type(content).__name__}>")
        if role == "assistant":
            analysis["assistant_reasoning"].append({"line": line, "chars": reasoning_chars})


def analyze_session(entries, observed):
    analysis = new_session_analysis(entries, observed)
    for entry in entries:
        if entry["time"] is None:
            mark_unknown(
                analysis, entry["line"],
                f"pi:{entry_type(entry['item'])}:missing-timestamp",
            )
    parse_pi(analysis)
    calls_by_id = {call["id"]: call for call in analysis["calls"] if call["id"] is not None}
    for result in analysis["results"]:
        call = calls_by_id.get(result["id"])
        if call is not None:
            result["name"] = result["name"] or call["name"]
            result["call_line"] = call["line"]
        else:
            result["call_line"] = None
        result["name"] = result["name"] or "(unknown)"
    return analysis


def json_number(value):
    if isinstance(value, float) and value.is_integer():
        return int(value)
    return value


def utc_text(value):
    return value.astimezone(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def session_facts(analysis):
    start, end = min(analysis["observed"]), max(analysis["observed"])
    duration = round((end - start).total_seconds() * 1000)
    unknown_rows = [
        {"entry": line, "shape": shape}
        for line, shape in sorted(analysis["unknown"].items())
    ]
    unknown_shapes = Counter(row["shape"] for row in unknown_rows)
    call_names = Counter(call["name"] for call in analysis["calls"])
    errors = [result for result in analysis["results"] if result["error"]]
    error_names = Counter(result["name"] for result in errors)
    token_usage = {
        field: int(round(analysis["token_totals"][field]))
        if analysis["token_present"][field]
        else None
        for field in TOKEN_FIELDS
    }
    reasoning_rows = [
        row for row in analysis["assistant_reasoning"] if row["chars"] > 0
    ]
    reasoning_top = sorted(
        reasoning_rows, key=lambda row: (-row["chars"], row["line"]),
    )[:3]
    return {
        "schema": "qq-observe.facts",
        "schema_version": 2,
        "session_format": analysis["format"],
        "entry_index_base": 1,
        "entries": len(analysis["entries"]),
        "turns_by_role": dict(sorted(analysis["turns"].items())),
        "message_blocks": {name: analysis["blocks"][name] for name in OBSERVE_BLOCKS},
        "reasoning": {
            "blocks": analysis["blocks"]["thinking"],
            "chars_total": sum(row["chars"] for row in analysis["assistant_reasoning"]),
            "chars_max_single_message": max(
                (row["chars"] for row in analysis["assistant_reasoning"]), default=0,
            ),
            "top_entries": [
                {"entry": row["line"], "chars": row["chars"]} for row in reasoning_top
            ],
        },
        "token_usage": token_usage,
        "token_usage_records": analysis["usage_records"],
        "tokens_unavailable": {
            field: analysis["token_unavailable"][field] for field in TOKEN_FIELDS
        },
        "tool_calls": {"total": len(analysis["calls"]), "by_name": dict(sorted(call_names.items()))},
        "tool_errors": {"total": len(errors), "by_name": dict(sorted(error_names.items()))},
        "wall_clock": {
            "start": utc_text(start),
            "end": utc_text(end),
            "duration_ms": json_number(duration),
        },
        "unknown_entries": {
            "total": len(unknown_rows),
            "by_shape": dict(sorted(unknown_shapes.items())),
            "entries": unknown_rows,
        },
    }


def matches_any(value, idioms):
    return any(idiom.search(value) for idiom in idioms)


def operator_request_call(call):
    name = call["name"]
    arguments = call["arguments"]
    if matches_any(name, OPERATOR_REQUEST_TOOL_NAME_IDIOMS):
        return True
    if matches_any(arguments, OPERATOR_REQUEST_ARGUMENT_IDIOMS):
        return True
    if (
        matches_any(name, HERDR_NOTIFICATION_TOOL_NAME_IDIOMS)
        and matches_any(arguments, NOTIFICATION_SHOW_ARGUMENT_IDIOMS)
    ):
        return True
    return (
        matches_any(name, HERDR_TOOL_NAME_IDIOMS)
        and matches_any(arguments, NOTIFICATION_ARGUMENT_IDIOMS)
        and matches_any(arguments, NOTIFICATION_SHOW_ARGUMENT_IDIOMS)
    )


def mutating_call(call):
    name = call["name"].lower()
    if name in MUTATING_TOOL_NAMES:
        return True
    return name == "bash" and matches_any(call["arguments"], COMMIT_SHAPED_COMMAND_IDIOMS)


def session_signals(analysis):
    episodes = []
    calls = sorted(analysis["calls"], key=lambda call: call["line"])
    errors = sorted(
        (result for result in analysis["results"] if result["error"]),
        key=lambda result: result["line"],
    )

    results_by_call = {}
    for result in analysis["results"]:
        if result["call_line"] is not None:
            results_by_call.setdefault(result["call_line"], []).append(result["line"])
    user_lines = sorted(line for line, _ in analysis["users"])
    agent_lines = [
        line for line, role in analysis["message_roles"] if role != "user"
    ]
    for request in (call for call in calls if operator_request_call(call)):
        next_user = next((line for line in user_lines if line > request["line"]), None)
        request_entries = [request["line"]] + [
            line for line in sorted(results_by_call.get(request["line"], []))
            if next_user is None or line < next_user
        ]
        if next_user is None:
            episodes.append({
                "kind": "operator_request_unacknowledged",
                "entries": list(dict.fromkeys(request_entries)),
            })
            continue
        intervening = sum(
            request["line"] < line < next_user for line in agent_lines
        )
        if intervening >= STALL_GAP_ENTRIES:
            episodes.append({
                "kind": "operator_request_stalled",
                "entries": list(dict.fromkeys(request_entries + [next_user])),
            })

    mutating_calls = [call for call in calls if mutating_call(call)]
    check_calls = [
        call for call in calls
        if call["name"].lower() in ("bash", "shell")
        and matches_any(call["arguments"], CHECK_SHAPED_COMMAND_IDIOMS)
    ]
    for claim_line, text in analysis["assistant_texts"]:
        if not COMPLETION_CLAIM_IDIOMS.search(text):
            continue
        previous_mutations = [
            call for call in mutating_calls if call["line"] < claim_line
        ]
        if not previous_mutations:
            continue
        mutation = previous_mutations[-1]
        verified = any(
            mutation["line"] < call["line"] < claim_line for call in check_calls
        )
        if not verified:
            episodes.append({
                "kind": "unverified_completion_claim",
                "entries": [mutation["line"], claim_line],
            })

    for result in errors:
        later = [
            call for call in calls
            if call["line"] > result["line"]
            and call["line"] - result["line"] <= SIGNAL_WINDOW
            and call["name"] == result["name"]
        ]
        if not later:
            continue
        retry = later[0]
        cited = [result.get("call_line"), result["line"], retry["line"]]
        episodes.append({
            "kind": "error_retry_loop",
            "entries": list(dict.fromkeys(line for line in cited if line is not None)),
        })

    identical = {}
    for call in calls:
        identical.setdefault((call["name"], call["arguments"]), []).append(call["line"])
    for lines in identical.values():
        if len(lines) >= 3:
            episodes.append({
                "kind": "repeated_identical_calls",
                "entries": list(dict.fromkeys(lines)),
            })

    for line, text in analysis["users"]:
        if CORRECTION.search(text):
            episodes.append({"kind": "operator_correction", "entries": [line]})

    compaction_groups = [[line] for line in sorted(analysis["compactions"])]
    episodes.extend(
        {"kind": "compaction", "entries": group}
        for group in compaction_groups
    )

    reasoning_by_line = {
        row["line"]: row["chars"] for row in analysis["assistant_reasoning"]
    }
    for line, chars in reasoning_by_line.items():
        if chars >= REASONING_VOLUME_CHARS:
            episodes.append({"kind": "reasoning_volume", "entries": [line]})

    contortion_run = []
    for line, role in analysis["message_roles"]:
        if role == "assistant" and reasoning_by_line.get(line, 0) >= REASONING_CONTORTION_CHARS:
            contortion_run.append(line)
            continue
        if len(contortion_run) >= REASONING_CONTORTION_MESSAGES:
            episodes.append({"kind": "reasoning_contortion", "entries": contortion_run})
        contortion_run = []
    if len(contortion_run) >= REASONING_CONTORTION_MESSAGES:
        episodes.append({"kind": "reasoning_contortion", "entries": contortion_run})

    index = 0
    while index + 2 < len(errors):
        stop = index
        while stop < len(errors) and errors[stop]["line"] - errors[index]["line"] <= SIGNAL_WINDOW:
            stop += 1
        if stop - index >= 3:
            episodes.append({
                "kind": "tool_error_burst",
                "entries": [result["line"] for result in errors[index:stop]],
            })
            index = stop
        else:
            index += 1

    unique = {}
    for episode in episodes:
        unique[(episode["kind"], tuple(episode["entries"]))] = episode
    ordered = sorted(
        unique.values(),
        key=lambda episode: (episode["entries"][0], episode["kind"], episode["entries"]),
    )
    return {
        "schema": "qq-observe.signals",
        "schema_version": 2,
        "session_format": analysis["format"],
        "entry_index_base": 1,
        "episodes": ordered,
    }


def analysis_object(value, required, label, optional=()):
    if not isinstance(value, dict):
        fail(f"analysis schema violation: {label} must be an object")
    required_fields = set(required)
    allowed_fields = required_fields | set(optional)
    missing = required_fields - value.keys()
    extra = value.keys() - allowed_fields
    if missing:
        fail(f"analysis schema violation: {label} missing {sorted(missing)[0]}")
    if extra:
        fail(f"analysis schema violation: {label} has unexpected {sorted(extra)[0]}")


def analysis_string(value, label, nonempty=False, maximum=None):
    if not isinstance(value, str) or (nonempty and not value):
        detail = "a non-empty string" if nonempty else "a string"
        fail(f"analysis schema violation: {label} must be {detail}")
    if maximum is not None and len(value) > maximum:
        fail(f"analysis schema violation: {label} exceeds {maximum} characters")


def bounded_integer(value, label, minimum=None, maximum=None):
    if isinstance(value, bool) or not isinstance(value, int):
        fail(f"{label} must be an integer")
    if minimum is not None and value < minimum:
        fail(f"{label} must be at least {minimum}")
    if maximum is not None and value > maximum:
        fail(f"{label} magnitude exceeds {maximum}")


def analysis_integer(value, label, **bounds):
    bounded_integer(value, f"analysis schema violation: {label}", **bounds)


def analysis_string_array(value, label, minimum=0):
    if not isinstance(value, list) or len(value) < minimum:
        fail(f"analysis schema violation: {label} must contain at least {minimum} paths")
    for index, item in enumerate(value):
        analysis_string(item, f"{label}[{index}]", nonempty=True)


def analysis_entry_array(value, label):
    if not isinstance(value, list) or not value:
        fail(f"analysis schema violation: {label} must contain at least one entry")
    for index, item in enumerate(value):
        analysis_integer(item, f"{label}[{index}]", minimum=1)


def refuse_duplicates(values, message):
    if len(set(values)) != len(values):
        fail(message)


def canonical_path(value):
    try:
        return os.path.realpath(value)
    except (ValueError, OSError) as error:
        fail(f"invalid path {value!r}: {error}")


def canonical_source(value):
    prefix, separator, path = value.partition(":")
    return f"{prefix}{separator}{canonical_path(path)}"


def validate_analysis_shape(item):
    if not isinstance(item, dict):
        fail("analysis schema violation: top level must be an object")
    if (
        item.get("schema") != "qq-observer.analysis"
        or isinstance(item.get("schema_version"), bool)
        or item.get("schema_version") != 1
    ):
        fail("analysis schema violation: unsupported schema or schema_version")

    if item.get("status") == "analysis_failed":
        analysis_object(
            item, {"schema", "schema_version", "status", "reason"}, "failure analysis",
        )
        analysis_string(item["reason"], "reason")
        return "failure"

    analysis_object(
        item,
        {"schema", "schema_version", "run", "episodes", "dropped_signals", "limitations"},
        "success analysis",
    )
    run = item["run"]
    analysis_object(run, {"change", "sessions"}, "run")
    analysis_string(run["change"], "run.change", nonempty=True)
    analysis_string_array(run["sessions"], "run.sessions", minimum=1)
    run["sessions"] = list(map(canonical_path, run["sessions"]))
    refuse_duplicates(run["sessions"], "duplicate session in run.sessions")

    episodes = item["episodes"]
    if not isinstance(episodes, list) or len(episodes) > 5:
        fail("analysis schema violation: episodes must be an array with at most 5 items")
    episode_fields = {
        "kind", "title", "sessions", "evidence", "what_happened", "root_cause",
        "root_cause_location", "cost", "remedy", "confidence", "confidence_why",
        "recurrence_key",
    }
    for episode_index, episode in enumerate(episodes):
        label = f"episodes[{episode_index}]"
        analysis_object(episode, episode_fields, label, optional={"rank", "no_signal"})
        if "rank" in episode:
            analysis_integer(episode["rank"], f"{label}.rank", minimum=1)
        if "no_signal" in episode and not isinstance(episode["no_signal"], bool):
            fail(f"analysis schema violation: {label}.no_signal must be a boolean")
        analysis_string(episode["kind"], f"{label}.kind")
        if episode["kind"] not in ANALYSIS_KINDS:
            fail(f"analysis schema violation: {label}.kind is not in the taxonomy")
        analysis_string(episode["title"], f"{label}.title", nonempty=True)
        analysis_string_array(episode["sessions"], f"{label}.sessions", minimum=1)
        episode["sessions"] = list(map(canonical_path, episode["sessions"]))
        refuse_duplicates(episode["sessions"], "duplicate session in episode.sessions")
        evidence = episode["evidence"]
        if not isinstance(evidence, list) or not evidence:
            fail(f"analysis schema violation: {label}.evidence must contain at least one citation")
        for evidence_index, citation in enumerate(evidence):
            citation_label = f"{label}.evidence[{evidence_index}]"
            analysis_object(citation, {"session", "entries", "quote"}, citation_label)
            analysis_string(citation["session"], f"{citation_label}.session")
            citation["session"] = canonical_path(citation["session"])
            analysis_entry_array(citation["entries"], f"{citation_label}.entries")
            refuse_duplicates(citation["entries"], "duplicate entry in citation")
            analysis_string(citation["quote"], f"{citation_label}.quote", maximum=200)
        for field in ("what_happened", "root_cause"):
            analysis_string(episode[field], f"{label}.{field}", nonempty=True)
        analysis_string(episode["root_cause_location"], f"{label}.root_cause_location")
        if episode["root_cause_location"] not in ANALYSIS_ROOT_CAUSE_LOCATIONS:
            fail(f"analysis schema violation: {label}.root_cause_location is invalid")
        cost = episode["cost"]
        analysis_object(cost, {"turns", "tokens", "duration_ms", "source"}, f"{label}.cost")
        for field in ("turns", "tokens", "duration_ms"):
            analysis_integer(cost[field], f"{label}.cost.{field}", minimum=0, maximum=SANE_SESSION_BOUND)
        analysis_string(cost["source"], f"{label}.cost.source", nonempty=True)
        cost["source"] = canonical_source(cost["source"])
        remedy = episode["remedy"]
        analysis_object(remedy, {"type", "smallest_change"}, f"{label}.remedy")
        analysis_string(remedy["type"], f"{label}.remedy.type", nonempty=True)
        analysis_string(
            remedy["smallest_change"], f"{label}.remedy.smallest_change", nonempty=True,
        )
        analysis_string(episode["confidence"], f"{label}.confidence")
        if episode["confidence"] not in ANALYSIS_CONFIDENCE:
            fail(f"analysis schema violation: {label}.confidence is invalid")
        analysis_string(episode["confidence_why"], f"{label}.confidence_why")
        analysis_string(episode["recurrence_key"], f"{label}.recurrence_key", nonempty=True)

    dropped = item["dropped_signals"]
    if not isinstance(dropped, list):
        fail("analysis schema violation: dropped_signals must be an array")
    for dropped_index, signal in enumerate(dropped):
        label = f"dropped_signals[{dropped_index}]"
        analysis_object(signal, {"kind", "entries", "why"}, label)
        analysis_string(signal["kind"], f"{label}.kind", nonempty=True)
        analysis_entry_array(signal["entries"], f"{label}.entries")
        analysis_string(signal["why"], f"{label}.why", nonempty=True)
    analysis_string(item["limitations"], "limitations")
    return "success"


def load_json_document(path, label):
    if not path.is_file():
        fail(f"{label} is not a regular file: {path}")
    try:
        raw = path.read_bytes()
        text = raw.decode("utf-8")
        return json.loads(
            text,
            parse_constant=lambda value: (_ for _ in ()).throw(
                ValueError(f"invalid JSON constant: {value}")
            ),
        )
    except (OSError, UnicodeDecodeError, ValueError, RecursionError) as error:
        fail(f"cannot read {label}: {error}")


def load_cost_facts(path, session):
    item = load_json_document(path, f"facts JSON for {session}")
    prefix = f"malformed facts JSON for {session}:"
    if not isinstance(item, dict):
        fail(f"{prefix} top level must be an object")
    if (
        item.get("schema") != "qq-observe.facts"
        or isinstance(item.get("schema_version"), bool)
        or item.get("schema_version") != 2
    ):
        fail(f"{prefix} unsupported schema or schema_version")

    turns = item.get("turns_by_role")
    if not isinstance(turns, dict):
        fail(f"{prefix} turns_by_role must be an object")
    for role, value in turns.items():
        if not isinstance(role, str):
            fail(f"{prefix} turns_by_role keys must be strings")
        bounded_integer(
            value, f"{prefix} turns_by_role value",
            minimum=0, maximum=SANE_SESSION_BOUND,
        )

    usage_records = item.get("token_usage_records")
    bounded_integer(
        usage_records, f"{prefix} token_usage_records",
        minimum=0, maximum=SANE_SESSION_BOUND,
    )
    token_usage = item.get("token_usage")
    if not isinstance(token_usage, dict):
        fail(f"{prefix} token_usage must be an object")
    token_total = 0
    for field in ("input", "output"):
        value = token_usage.get(field)
        if value is not None:
            bounded_integer(
                value, f"{prefix} token_usage.{field}",
                minimum=0, maximum=SANE_SESSION_BOUND,
            )
            if usage_records == 0:
                fail(f"{prefix} zero usage records require null token_usage.{field}")
            token_total += value

    wall_clock = item.get("wall_clock")
    if not isinstance(wall_clock, dict):
        fail(f"{prefix} wall_clock must be an object")
    duration = wall_clock.get("duration_ms")
    bounded_integer(
        duration, f"{prefix} wall_clock.duration_ms", minimum=0, maximum=SANE_SESSION_BOUND,
    )
    return {
        "turns": sum(turns.values()),
        "tokens": token_total,
        "tokens_verifiable": usage_records > 0,
        "duration_ms": duration,
    }


def quotable_entry_text(item):
    if not isinstance(item, dict) or item.get("type") != "message":
        return ""
    message = item.get("message")
    if not isinstance(message, dict):
        return ""
    content = message.get("content")
    if isinstance(content, str):
        return content
    if not isinstance(content, list):
        return ""
    texts = []
    for block in content:
        if not isinstance(block, dict):
            continue
        if block.get("type") == "text" and isinstance(block.get("text"), str):
            texts.append(block["text"])
        elif block.get("type") == "thinking" and isinstance(block.get("thinking"), str):
            texts.append(block["thinking"])
    return "\n".join(texts)


def normalized_whitespace(value):
    return re.sub(r"\s+", " ", value).strip()


def cost_mismatch(field, expected, actual):
    fail(f"cost.{field} mismatch: expected {expected!r}, actual {actual!r}")


def parse_analysis_package(values):
    if len(values) < 2 or values[0].startswith("--"):
        fail(
            "validate-analysis requires an analysis JSON, at least one session JSONL, "
            "and one --facts pair per session"
        )
    analysis_path = Path(canonical_path(values[0]))
    supplied = []
    facts_paths = {}
    index = 1
    while index < len(values):
        value = values[index]
        if value == "--facts":
            if index + 1 >= len(values):
                fail("--facts requires SESSION_PATH=FACTS_PATH")
            pair = values[index + 1]
            if "=" not in pair:
                fail("--facts requires SESSION_PATH=FACTS_PATH")
            session, facts_path = pair.split("=", 1)
            if not session or not facts_path:
                fail("--facts requires non-empty session and facts paths")
            session = canonical_path(session)
            if session in facts_paths:
                fail(f"duplicate --facts session: {session}")
            facts_paths[session] = Path(canonical_path(facts_path))
            index += 2
            continue
        if value.startswith("--"):
            fail(f"unknown validate-analysis option: {value}")
        supplied.append(canonical_path(value))
        index += 1

    if not supplied:
        fail("validate-analysis requires at least one session JSONL")
    if len(set(supplied)) != len(supplied):
        fail("duplicate session JSONL path")
    unknown_facts = set(facts_paths) - set(supplied)
    if unknown_facts:
        fail(f"--facts references unknown session: {sorted(unknown_facts)[0]}")
    missing_facts = set(supplied) - set(facts_paths)
    if missing_facts:
        fail(f"missing --facts for session: {sorted(missing_facts)[0]}")
    return analysis_path, supplied, facts_paths


def validate_episode_cost(episode, facts):
    expected_turns = 0
    expected_tokens = 0
    tokens_verifiable = False
    expected_duration_ms = 0
    for session in episode["sessions"]:
        record = facts[session]
        expected_turns += record["turns"]
        expected_duration_ms += record["duration_ms"]
        if record["tokens_verifiable"]:
            tokens_verifiable = True
            expected_tokens += record["tokens"]

    cost = episode["cost"]
    if cost["turns"] != expected_turns:
        cost_mismatch("turns", expected_turns, cost["turns"])
    if tokens_verifiable and cost["tokens"] != expected_tokens:
        cost_mismatch("tokens", expected_tokens, cost["tokens"])
    if cost["duration_ms"] != expected_duration_ms:
        cost_mismatch("duration_ms", expected_duration_ms, cost["duration_ms"])
    expected_source = f"facts:{episode['sessions'][0]}"
    if cost["source"] != expected_source:
        cost_mismatch("source", expected_source, cost["source"])


def validate_and_rank_analysis(values):
    global analysis_validation_mode
    analysis_validation_mode = True
    analysis_path, supplied, facts_paths = parse_analysis_package(values)
    item = load_json_document(analysis_path, "analysis JSON")

    session_lines = {}
    facts = {}
    for value in supplied:
        path = Path(value)
        if not path.is_file():
            fail(f"session JSONL is not a regular file: {path}")
        session_entries, _ = session_jsonl(path)
        session_lines[value] = {
            entry["line"]: entry["item"] for entry in session_entries
        }
        facts[value] = load_cost_facts(facts_paths[value], value)

    form = validate_analysis_shape(item)
    if form == "failure":
        print(json.dumps(item, separators=(",", ":"), sort_keys=True))
        return

    declared = item["run"]["sessions"]
    if set(declared) != set(supplied) or len(declared) != len(supplied):
        fail("analysis run.sessions does not match the supplied session package")
    for episode in item["episodes"]:
        for session in episode["sessions"]:
            if session not in session_lines:
                fail(f"episode references unknown session: {session}")
        for citation in episode["evidence"]:
            session = citation["session"]
            if session not in session_lines:
                fail(f"citation references unknown session: {session}")
            cited_texts = []
            for entry in citation["entries"]:
                if entry not in session_lines[session]:
                    fail(f"citation entry {entry} does not exist in session: {session}")
                entry_text = quotable_entry_text(session_lines[session][entry])
                if not normalized_whitespace(entry_text):
                    fail("citation carries no quotable text")
                cited_texts.append(entry_text)
            cited_text = normalized_whitespace(" ".join(cited_texts))
            quote = normalized_whitespace(citation["quote"])
            if not quote:
                fail("citation quote is empty after whitespace normalization")
            if quote not in cited_text:
                fail("citation quote is not verbatim in the cited entries")
        validate_episode_cost(episode, facts)

    ranked = sorted(
        item["episodes"],
        key=lambda episode: (
            -ANALYSIS_CONFIDENCE[episode["confidence"]],
            -episode["cost"]["tokens"],
            episode["title"],
        ),
    )
    output = dict(item)
    output["episodes"] = [dict(episode, rank=index) for index, episode in enumerate(ranked, 1)]
    print(json.dumps(output, separators=(",", ":"), sort_keys=True))


def emit(options, start, end):
    if end < start: fail("end timestamp precedes start timestamp")
    phase = options.get("phase")
    if phase and phase not in PHASES: fail(f"unknown SDLC phase: {phase}")
    trace_id, span_id, parent, root = context(options)
    record = {
        "schema_version": 1,
        "trace_id": trace_id,
        "span_id": span_id,
        "parent_span_id": parent,
        "root_span_id": root,
        "name": options["name"],
        "phase": phase,
        "actor": options["actor"],
        "start_time": start.isoformat(),
        "end_time": end.isoformat(),
        "duration_ms": round((end - start).total_seconds() * 1000, 3),
        "status": options.get("status", "ok"),
        "source": options.get("source", "qq-observe"),
        "attributes": options["attributes"],
    }
    append(record)
    print(json.dumps({k: record[k] for k in ("trace_id", "span_id", "root_span_id")}, separators=(",", ":")))

if command == "validate-analysis":
    validate_and_rank_analysis(args)
    raise SystemExit(0)

if command == "summarize":
    summary_options = parse_summary_options(args)
    summary = aggregate_summary(summary_options)
    if summary_options["json"]:
        print(json.dumps(summary, separators=(",", ":")))
    else:
        print_summary(summary)
    raise SystemExit(0)

if command in {"facts", "signals"}:
    if len(args) != 1 or args[0].startswith("--"):
        fail(f"{command} requires exactly one session JSONL path")
    path = Path(args[0])
    if not path.is_file():
        fail(f"session JSONL is not a regular file: {path}")
    session_entries, observed = session_jsonl(path)
    analysis = analyze_session(session_entries, observed)
    result = session_facts(analysis) if command == "facts" else session_signals(analysis)
    print(json.dumps(result, separators=(",", ":"), sort_keys=True))
    raise SystemExit(0)

options = parse_options(args, session=command == "read-session")
if command == "record":
    for required in ("name", "actor", "start", "end"):
        if not options.get(required): fail(f"--{required} is required")
    emit(options, timestamp(options["start"]), timestamp(options["end"]))
else:
    path = Path(options["session"])
    if not path.is_file(): fail(f"session JSONL is not a regular file: {path}")
    session_entries, observed = session_jsonl(path, legacy=True)
    options.setdefault("name", "invoke_workflow")
    options.setdefault("actor", "accountable-session")
    options.setdefault("source", "pi-session-jsonl")
    options["attributes"].update({"session.file": str(path.resolve()), "session.entries": len(session_entries)})
    emit(options, min(observed), max(observed))
