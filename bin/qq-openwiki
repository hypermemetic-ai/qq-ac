#!/usr/bin/env bash
# Run OpenWiki locally without retaining its generated repository setup.
set -euo pipefail

die() {
  printf 'qq-openwiki: %s\n' "$*" >&2
  exit 1
}

case "${1:-}" in
  --init | --update)
    mode="$1"
    openwiki_mode="$1"
    shift
    ;;
  --correct)
    mode="$1"
    openwiki_mode="--update"
    shift
    ;;
  *) die "usage: qq-openwiki {--init|--update|--correct} [OpenWiki options or message]" ;;
esac

case "${OPENWIKI_PROVIDER:-}" in
  "" | openai-chatgpt) ;;
  *) die "OPENWIKI_PROVIDER must be openai-chatgpt (local ChatGPT OAuth only)" ;;
esac

if [ -n "${OPENWIKI_BIN:-}" ]; then
  case "$OPENWIKI_BIN" in
    /*) ;;
    *) die "OPENWIKI_BIN must be an absolute executable file: $OPENWIKI_BIN" ;;
  esac
  if [ ! -f "$OPENWIKI_BIN" ] || [ ! -x "$OPENWIKI_BIN" ]; then
    die "OPENWIKI_BIN must be an absolute executable file: $OPENWIKI_BIN"
  fi
  openwiki_bin="$OPENWIKI_BIN"
else
  openwiki_bin="$(command -v openwiki 2>/dev/null || true)"
  [ -n "$openwiki_bin" ] || die "openwiki not found; set OPENWIKI_BIN to its absolute path"
fi

self="$(readlink -f -- "${BASH_SOURCE[0]}")"
diagram_tool="$(dirname "$self")/qq-openwiki-bpmn"
if [ ! -f "$diagram_tool" ] || [ ! -x "$diagram_tool" ]; then
  die "OpenWiki BPMN publisher is missing or not executable: $diagram_tool"
fi
printf -v diagram_tool_command '%q' "$diagram_tool"
if [ -n "${QQ_OPENWIKI_NODE_BIN:-}" ]; then
  case "$QQ_OPENWIKI_NODE_BIN" in
    /*) node_bin="$QQ_OPENWIKI_NODE_BIN" ;;
    *) die "QQ_OPENWIKI_NODE_BIN must be an absolute executable file" ;;
  esac
else
  node_bin="$(command -v node 2>/dev/null || true)"
  if [ -z "$node_bin" ] && [ -x "$(dirname "$openwiki_bin")/node" ]; then
    node_bin="$(dirname "$openwiki_bin")/node"
  fi
fi
[ -n "${node_bin:-}" ] \
  || die "node not found; set QQ_OPENWIKI_NODE_BIN to its absolute path"
node_bin="$(readlink -f -- "$node_bin")"
if [ ! -f "$node_bin" ] || [ ! -x "$node_bin" ]; then
  die "QQ_OPENWIKI_NODE_BIN must be an absolute executable file"
fi
printf -v node_bin_command '%q' "$node_bin"
diagram_publish_command="QQ_OPENWIKI_NODE_BIN=$node_bin_command $diagram_tool_command"

command -v git >/dev/null 2>&1 || die "git not found"
command -v flock >/dev/null 2>&1 || die "flock not found"
command -v sha256sum >/dev/null 2>&1 || die "sha256sum not found"

root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not inside a Git worktree"
cd "$root"
root="$(pwd -P)"

require_correction_snapshot() {
  local path
  local staged=0

  while IFS= read -r -d '' path; do
    staged=1
    case "$path" in
      openwiki/*) ;;
      *) die "correction snapshot is outside openwiki/: $path" ;;
    esac
  done < <(git diff --cached --name-only -z --)

  [ "$staged" -eq 1 ] \
    || die "correction requires a staged generated snapshot"
  git diff --quiet -- \
    || die "correction baseline must be fully staged"
  [ -z "$(git ls-files --others --exclude-standard)" ] \
    || die "correction baseline must be fully staged"
}

absolute_common_dir() {
  local worktree="$1"
  local directory

  directory="$(git -C "$worktree" rev-parse --git-common-dir 2>/dev/null)" \
    || return 1
  case "$directory" in
    /*) ;;
    *) directory="$(cd "$worktree/$(dirname "$directory")" && pwd -P)/$(basename "$directory")" ;;
  esac
  printf '%s\n' "$directory"
}

common_dir="$(absolute_common_dir "$root")" \
  || die "failed to resolve the Repository common directory"
lock_key="$(printf '%s' "$common_dir" | sha256sum | cut -d' ' -f1)"
lock_root="${XDG_RUNTIME_DIR:-${TMPDIR:-/tmp}}/qq-openwiki"
umask 077
mkdir -p "$lock_root"
exec 9>"$lock_root/$lock_key.lock"
flock -n 9 || die "another OpenWiki writer is active for this Repository"

workflow=".github/workflows/openwiki-update.yml"
if [ -n "${XDG_STATE_HOME:-}" ]; then
  state_home="$XDG_STATE_HOME"
elif [ -n "${HOME:-}" ]; then
  state_home="$HOME/.local/state"
else
  die "XDG_STATE_HOME or HOME is required for durable snapshots"
fi
state_root="$state_home/qq/openwiki"
state_dir="$state_root/$lock_key"
preparing_state_dir="$state_root/.$lock_key.preparing"
restored_state_dir="$state_root/.$lock_key.restored"
snapshot_root_file="$state_dir/worktree-root"
mkdir -p -- "$state_root"
if [ ! -d "$state_root" ] || [ -L "$state_root" ]; then
  die "refusing unsupported snapshot root: $state_root"
fi
chmod 700 -- "$state_root"

cleanup_done=0
restore_root="$root"

load_snapshot_root() {
  local actual_root
  local snapshot_common_dir
  local trailing

  if [ ! -f "$snapshot_root_file" ] || [ -L "$snapshot_root_file" ]; then
    die "durable OpenWiki snapshot has no valid worktree root"
  fi
  exec 8<"$snapshot_root_file" \
    || die "failed to read the durable OpenWiki snapshot root"
  if ! IFS= read -r -d '' restore_root <&8; then
    exec 8<&-
    die "durable OpenWiki snapshot has no valid worktree root"
  fi
  if IFS= read -r -n 1 trailing <&8; then
    : "$trailing"
    exec 8<&-
    die "durable OpenWiki snapshot has an invalid worktree root"
  fi
  exec 8<&-

  case "$restore_root" in
    /*) ;;
    *) die "durable OpenWiki snapshot has an invalid worktree root" ;;
  esac
  if [ ! -d "$restore_root" ] || [ -L "$restore_root" ]; then
    die "durable OpenWiki snapshot worktree is unavailable: $restore_root"
  fi
  actual_root="$(git -C "$restore_root" rev-parse --show-toplevel 2>/dev/null)" \
    || die "durable OpenWiki snapshot worktree is unavailable: $restore_root"
  actual_root="$(cd "$actual_root" && pwd -P)"
  [ "$actual_root" = "$restore_root" ] \
    || die "durable OpenWiki snapshot worktree has changed: $restore_root"
  snapshot_common_dir="$(absolute_common_dir "$restore_root")" \
    || die "failed to validate the durable OpenWiki snapshot Repository"
  [ "$snapshot_common_dir" = "$common_dir" ] \
    || die "durable OpenWiki snapshot belongs to a different Repository"
}

restore_local_setup() {
  local name
  local path
  local status=0

  [ "$cleanup_done" -eq 0 ] || return 0
  cleanup_done=1
  rm -f "$restore_root/$workflow" || status=1
  rmdir "$restore_root/.github/workflows" "$restore_root/.github" 2>/dev/null || true

  for name in AGENTS.md CLAUDE.md; do
    path="$restore_root/$name"
    if [ -d "$path" ] && [ ! -L "$path" ]; then
      status=1
      continue
    fi
    rm -f -- "$path" || status=1
    if [ -L "$state_dir/$name" ] || [ -f "$state_dir/$name" ]; then
      cp -a -- "$state_dir/$name" "$path" || status=1
    fi
  done

  if [ "$status" -eq 0 ]; then
    rm -rf -- "$restored_state_dir" || status=1
  fi
  if [ "$status" -eq 0 ]; then
    mv -T -- "$state_dir" "$restored_state_dir" || status=1
  fi
  if [ ! -e "$state_dir" ] && [ ! -L "$state_dir" ]; then
    rm -rf -- "$restored_state_dir" || status=1
  fi
  return "$status"
}

rm -rf -- "$preparing_state_dir" "$restored_state_dir" \
  || die "failed to clean incomplete snapshot state"
if [ -e "$state_dir" ] || [ -L "$state_dir" ]; then
  if [ ! -d "$state_dir" ] || [ -L "$state_dir" ]; then
    die "refusing unsupported snapshot path: $state_dir"
  fi
  load_snapshot_root
  restore_local_setup || die "failed to restore stale OpenWiki snapshot"
fi

if [ -e "$workflow" ] || [ -L "$workflow" ]; then
  die "refusing to replace existing $workflow"
fi

if [ "$mode" = "--update" ] || [ "$mode" = "--correct" ]; then
  branch="$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  [ "$branch" = "openwiki/update" ] \
    || die "updates require the dedicated openwiki/update branch (current: ${branch:-detached})"
  [ -d openwiki ] || die "openwiki/ is absent; initialize it first"
  if [ "$mode" = "--update" ]; then
    [ -z "$(git status --porcelain --untracked-files=all)" ] \
      || die "update worktree must be clean"
  else
    require_correction_snapshot
  fi
  main="$(git rev-parse --verify origin/main 2>/dev/null)" \
    || die "origin/main is unavailable; fetch origin first"
  [ "$(git rev-parse HEAD)" = "$main" ] \
    || die "openwiki/update must equal current origin/main; fetch and fast-forward it first"
elif [ -e openwiki ]; then
  die "openwiki/ already exists; use --update"
fi

mkdir -- "$preparing_state_dir" \
  || die "failed to prepare durable OpenWiki snapshot"
printf '%s\0' "$root" >"$preparing_state_dir/worktree-root"

snapshot_agent_file() {
  local name="$1"

  if [ -L "$name" ] || [ -f "$name" ]; then
    cp -a -- "$name" "$preparing_state_dir/$name"
  elif [ -e "$name" ]; then
    rm -rf -- "$preparing_state_dir"
    die "refusing unsupported agent-instruction path: $name"
  else
    return 0
  fi
}

shadow_agent_symlink() {
  local name="$1"
  local shadow

  # OpenWiki follows symlinks. Give it a local regular-file shadow so a linked
  # shared instruction source cannot be modified during generation.
  if [ -L "$name" ]; then
    shadow="$state_dir/$name.shadow"
    cp -L -p -- "$name" "$shadow"
    rm -- "$name"
    mv -- "$shadow" "$name"
  fi
}

snapshot_agent_file AGENTS.md
snapshot_agent_file CLAUDE.md
mv -T -- "$preparing_state_dir" "$state_dir" \
  || die "failed to activate durable OpenWiki snapshot"
restore_root="$root"
cleanup_done=0
trap 'restore_local_setup >/dev/null 2>&1 || true' EXIT
shadow_agent_symlink AGENTS.md
shadow_agent_symlink CLAUDE.md

diagram_instruction="$(printf '%s\n' \
  'OpenWiki BPMN authoring extension:' \
  'You, the internal OpenWiki generator, own diagram selection and authorship during this run. While inspecting source and writing the narrative wiki, decide whether any concrete multi-step, branching, lifecycle, retry, or failure process would become materially easier to understand as BPMN. There is no diagram quota. Do not diagram a process when prose is equally clear.' \
  'For each useful process, create openwiki/processes/<id>.json. The filename must equal the stable BPMN process id. The JSON object requires id, name, elements, and flows. Every element requires id, type, name, non-empty documentation, and evidence with non-empty source-relative file and lines strings. Every flow requires id, source, target, non-empty documentation, and the same evidence object; name is optional. Supported element types are startEvent, endEvent, serviceTask, userTask, manualTask, exclusiveGateway, and boundaryEvent. An error end event may set error=true. A boundaryEvent also sets attachedTo and kind=error or kind=timer; timer boundaries require an ISO 8601 duration, and cancelActivity is optional.' \
  "After writing a spec, publish it with exactly: $diagram_publish_command openwiki/processes/<id>.json" \
  "Verify a published spec with exactly: $diagram_publish_command --check openwiki/processes/<id>.json" \
  'That command verifies every cited source file and line range inside the Repository, lints and lays out the model, checks lossless evidence round trips and repeat-generation determinism, then publishes only <id>.bpmn and the visibly attributed <id>.png beside the spec. Treat both as generated artifacts: never hand-edit them and never publish pipeline SVG, layout, or round-trip intermediates.' \
  'Source-range validity is necessary but not sufficient. Before retaining a spec, trace every sequence flow source, target, label, and retry or failure outcome against the behavior justified by its citation. Omit the diagram when an edge is not supported.' \
  'Prefer a compact process abstraction over mirroring every source statement. Keep labels short and combine low-level steps when that preserves the material decisions and outcomes. Inspect the image at a representative Markdown content width and at its linked full resolution. Keep it only when the process can be followed at embed width and labels are readable in the linked original. Aspect ratio, pixel width, or panoramic shape alone is not a defect.' \
  'Embed each generated PNG from the Markdown page that explains the process, using the correct relative image path and retaining enough prose to orient the reader. Put the linked image on a standalone Markdown line and keep the surrounding narrative coherent without the optional image. Make the embedded image a link to the same PNG so full resolution is one click away. Inspect the rendered result and keep it only when it genuinely clarifies the process.' \
  'On updates, evaluate existing openwiki/processes specs and Markdown links too. Update and republish diagrams that remain useful; remove the JSON, BPMN, PNG, and link together when the process is gone, materially changed beyond recognition, or no longer benefits from a diagram. Before finishing, run the publisher in --check mode for every retained spec in stable filename order.' \
  'Keep all authored wiki and diagram files under openwiki/.')"

set +e
OPENWIKI_PROVIDER="openai-chatgpt" QQ_OPENWIKI_NODE_BIN="$node_bin" \
  "$openwiki_bin" code "$openwiki_mode" --print "$@" "$diagram_instruction"
run_status=$?
set -e

cleanup_status=0
restore_local_setup || cleanup_status=$?
trap - EXIT

[ "$run_status" -eq 0 ] || exit "$run_status"
[ "$cleanup_status" -eq 0 ] || exit "$cleanup_status"
