#!/usr/bin/env bash
# Run one pi-subagents child beneath its role-selected Landstrip policy.
# shellcheck disable=SC1091
set -euo pipefail

umask 077

fail() {
  local exit_code="$1"
  shift
  printf '[qq-dispatch] fail-closed: %s\n' "$*" >&2
  exit "$exit_code"
}

path_is_within() {
  local candidate="$1"
  local parent="$2"
  [[ "$candidate" == "$parent" || "$candidate" == "$parent"/* ]]
}

self="$(readlink -f -- "${BASH_SOURCE[0]}")" \
  || fail 64 "cannot resolve the adapter path"
bin_dir="$(cd -- "$(dirname -- "$self")" && pwd -P)" \
  || fail 64 "cannot resolve the adapter directory"
adapter_worktree="$(cd -- "$bin_dir/.." && pwd -P)" \
  || fail 64 "cannot resolve the adapter worktree"

# shellcheck source=bin/lib/qq-bin.sh
source "$bin_dir/lib/qq-bin.sh"

if ! qq_resolve_bin git; then
  fail 64 "$QQ_BIN_ERROR"
fi
git_binary="$QQ_BIN_RESULT"

git_query() {
  (
    unset "${!GIT_@}"
    "$git_binary" "$@"
  )
}

if ! adapter_repository_root="$(git_query -C "$adapter_worktree" rev-parse --show-toplevel 2>/dev/null)"; then
  fail 64 "adapter is not installed in a Git worktree"
fi
if ! adapter_repository_root="$(realpath -e -- "$adapter_repository_root" 2>/dev/null)"; then
  fail 64 "cannot resolve the adapter's Git worktree"
fi
[[ "$adapter_repository_root" == "$adapter_worktree" ]] \
  || fail 64 "adapter path does not resolve beneath its assigned worktree"

if ! adapter_git_common_dir="$(git_query -C "$adapter_worktree" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"; then
  fail 67 "cannot discover the Git common directory"
fi
if ! adapter_git_common_dir="$(realpath -e -- "$adapter_git_common_dir" 2>/dev/null)"; then
  fail 67 "cannot resolve the Git common directory"
fi

invocation_cwd="$(pwd -P)" || fail 65 "cannot resolve the child cwd"
if ! invocation_root="$(git_query -C "$invocation_cwd" rev-parse --show-toplevel 2>/dev/null)"; then
  fail 65 "child cwd is not a Git worktree"
fi
if ! invocation_root="$(realpath -e -- "$invocation_root" 2>/dev/null)"; then
  fail 65 "cannot resolve the child cwd's Git worktree"
fi

if ! git_common_dir="$(git_query -C "$invocation_root" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"; then
  fail 67 "cannot discover the Git common directory"
fi
if ! git_worktree_dir="$(git_query -C "$invocation_root" rev-parse --path-format=absolute --git-dir 2>/dev/null)"; then
  fail 67 "cannot discover the worktree Git directory"
fi
if ! git_common_dir="$(realpath -e -- "$git_common_dir" 2>/dev/null)"; then
  fail 67 "cannot resolve the Git common directory"
fi
if ! git_worktree_dir="$(realpath -e -- "$git_worktree_dir" 2>/dev/null)"; then
  fail 67 "cannot resolve the worktree Git directory"
fi

if path_is_within "$self" "$invocation_root"; then
  [[ "$invocation_root" == "$adapter_worktree" ]] \
    || fail 65 "adapter path resolves beneath an unrelated repository worktree"
else
  [[ "$git_common_dir" == "$adapter_git_common_dir" ]] \
    || fail 65 "child cwd belongs to an unrelated repository"
fi
worktree="$invocation_root"

role="${PI_SUBAGENT_CHILD_AGENT:-}"
case "$role" in
  reviewer | researcher | implementer) ;;
  "") fail 66 "PI_SUBAGENT_CHILD_AGENT is required" ;;
  *) fail 66 "unsupported child role '$role'" ;;
esac

roles_file="$adapter_worktree/delegation/policies/roles.json"
policy_renderer="$bin_dir/lib/qq-render-landstrip-policy.mjs"
tree_supervisor="$bin_dir/lib/qq-process-tree-supervisor.py"
[[ -f "$roles_file" && -r "$roles_file" ]] \
  || fail 72 "Landstrip role policy is unavailable"
[[ -f "$policy_renderer" && -r "$policy_renderer" ]] \
  || fail 72 "Landstrip policy renderer is unavailable"
[[ -f "$tree_supervisor" && -x "$tree_supervisor" ]] \
  || fail 71 "process-tree supervisor is unavailable"

runtime_root_input="${QQ_DISPATCH_RUNTIME_ROOT:-${TMPDIR:-/tmp}/qq-delegate-runtime}"
[[ "$runtime_root_input" == /* ]] \
  || fail 68 "QQ_DISPATCH_RUNTIME_ROOT must be absolute"
mkdir -p -- "$runtime_root_input" \
  || fail 68 "cannot create the dispatch runtime root"
if ! runtime_root="$(realpath -e -- "$runtime_root_input" 2>/dev/null)"; then
  fail 68 "cannot resolve the dispatch runtime root"
fi
if ! system_tmp="$(realpath -e -- /tmp 2>/dev/null)"; then
  fail 68 "cannot resolve /tmp"
fi
path_is_within "$runtime_root" "$system_tmp" \
  || fail 68 "runtime root must stay beneath /tmp"
[[ "$runtime_root" != "$system_tmp" ]] \
  || fail 68 "runtime root may not be all of /tmp"

structured_output_capture=""
if [[ -n "${PI_SUBAGENT_STRUCTURED_OUTPUT_CAPTURE:-}" ]]; then
  capture_input="$PI_SUBAGENT_STRUCTURED_OUTPUT_CAPTURE"
  [[ "$capture_input" == /* ]] \
    || fail 68 "structured-output capture path must be absolute"
  [[ ! -L "$capture_input" ]] \
    || fail 68 "structured-output capture path may not be a symlink"
  capture_parent_input="$(dirname -- "$capture_input")"
  [[ -d "$capture_parent_input" ]] \
    || fail 68 "structured-output capture directory is unavailable"
  if ! capture_parent="$(realpath -e -- "$capture_parent_input" 2>/dev/null)"; then
    fail 68 "cannot resolve the structured-output capture directory"
  fi
  capture_leaf="$(basename -- "$capture_input")"
  [[ -n "$capture_leaf" && "$capture_leaf" != "." && "$capture_leaf" != ".." ]] \
    || fail 68 "structured-output capture filename is invalid"
  structured_output_capture="$capture_parent/$capture_leaf"
  if ! path_is_within "$structured_output_capture" "$runtime_root" \
    && ! path_is_within "$structured_output_capture" "$worktree"; then
    fail 68 "structured-output capture path must stay beneath the runtime root or assigned worktree"
  fi
fi

run_token="${PI_SUBAGENT_RUN_ID:-manual}"
run_token="${run_token//[^A-Za-z0-9._-]/_}"
run_token="${run_token:0:80}"
[[ -n "$run_token" ]] || run_token="manual"
child_index="${PI_SUBAGENT_CHILD_INDEX:-0}"
[[ "$child_index" =~ ^[0-9]+$ ]] \
  || fail 68 "PI_SUBAGENT_CHILD_INDEX must be a non-negative integer"
run_dir="$runtime_root/runs/$run_token/${role}-${child_index}-$$"
mkdir -p -- "$run_dir/tmp" "$run_dir/pi-config" "$run_dir/sessions" \
  || fail 68 "cannot create the dispatch run directories"

if ! qq_resolve_bin node; then
  fail 69 "$QQ_BIN_ERROR"
fi
node_binary="$QQ_BIN_RESULT"

if [[ -n "${QQ_LANDSTRIP_BIN:-}" ]]; then
  if ! qq_resolve_bin landstrip; then
    fail 69 "$QQ_BIN_ERROR"
  fi
  landstrip_binary="$QQ_BIN_RESULT"
else
  if ! platform="$("$node_binary" -p 'process.platform' 2>/dev/null)" \
    || ! architecture="$("$node_binary" -p 'process.arch' 2>/dev/null)"; then
    fail 69 "cannot determine the Landstrip platform package"
  fi
  landstrip_binary="$adapter_worktree/.pi/npm/node_modules/@landstrip/landstrip-${platform}-${architecture}/bin/landstrip"
fi
[[ "$landstrip_binary" == /* ]] \
  || fail 69 "Landstrip binary path must be absolute"
[[ -f "$landstrip_binary" && -x "$landstrip_binary" ]] \
  || fail 69 "Landstrip is unavailable at the configured path"
if ! landstrip_binary="$(realpath -e -- "$landstrip_binary" 2>/dev/null)"; then
  fail 69 "cannot resolve the Landstrip binary"
fi
if ! landstrip_version="$("$landstrip_binary" --version 2>&1)"; then
  fail 69 "Landstrip version probe failed: $landstrip_version"
fi

if ! qq_resolve_bin pi; then
  fail 70 "$QQ_BIN_ERROR"
fi
pi_binary="$QQ_BIN_RESULT"
if ! pi_binary="$(realpath -e -- "$pi_binary" 2>/dev/null)"; then
  fail 70 "cannot resolve the Pi binary"
fi
[[ "$pi_binary" != "$self" ]] \
  || fail 70 "Pi target cannot recurse into the adapter"

timeout_spec="${QQ_DISPATCH_TIMEOUT:-30m}"
[[ "$timeout_spec" =~ ^(0\.[0-9]+|[1-9][0-9]*(\.[0-9]+)?)([smhd])?$ ]] \
  || fail 71 "invalid QQ_DISPATCH_TIMEOUT '$timeout_spec'"
if ! qq_resolve_bin timeout; then
  fail 71 "$QQ_BIN_ERROR"
fi
timeout_binary="$QQ_BIN_RESULT"
if ! qq_resolve_bin python3; then
  fail 71 "$QQ_BIN_ERROR"
fi
python_binary="$QQ_BIN_RESULT"

policy_path="$run_dir/landstrip-policy.json"
event_log="$runtime_root/wrapper-events.jsonl"
if ! metadata="$("$node_binary" "$policy_renderer" \
  --roles "$roles_file" \
  --role "$role" \
  --run-id "$run_token" \
  --worktree "$worktree" \
  --git-common-dir "$git_common_dir" \
  --git-worktree-dir "$git_worktree_dir" \
  --runtime-root "$runtime_root" \
  --structured-output-capture "$structured_output_capture" \
  --policy "$policy_path" \
  --event-log "$event_log" \
  --timeout "$timeout_spec" \
  --landstrip-version "$landstrip_version")"; then
  fail 72 "Landstrip policy rendering failed"
fi
IFS=$'\t' read -r policy_identity access_scope <<< "$metadata"
[[ -n "$policy_identity" && -n "$access_scope" ]] \
  || fail 72 "Landstrip policy renderer returned incomplete metadata"

export QQ_DISPATCH_WORKTREE="$worktree"
export QQ_DISPATCH_GIT_COMMON_DIR="$git_common_dir"
export QQ_DISPATCH_GIT_WORKTREE_DIR="$git_worktree_dir"
export QQ_DISPATCH_RUN_DIR="$run_dir"
export QQ_DISPATCH_POLICY_IDENTITY="$policy_identity"
export QQ_DISPATCH_POLICY_SCOPE="$access_scope"
export QQ_DISPATCH_WRAPPER_EVENT_LOG="$event_log"
export TMPDIR="$run_dir/tmp"
export PI_CODING_AGENT_DIR="$run_dir/pi-config"
export PI_CODING_AGENT_SESSION_DIR="$run_dir/sessions"
export PI_OFFLINE=1

printf '[qq-dispatch] role=%s policy=%s scope=%s boundary=landstrip landstrip=%s timeout=%s\n' \
  "$role" "$policy_identity" "$access_scope" "$landstrip_version" "$timeout_spec" >&2

exec "$timeout_binary" -k 10 --signal=TERM "$timeout_spec" \
  "$python_binary" "$tree_supervisor" -- \
  "$landstrip_binary" -p "$policy_path" \
  "$pi_binary" --approve --offline "$@"
