#!/usr/bin/env bash
# Resolve a Repository's persistent main-checkout Herdr home. Inspection is
# read-only; focus actions find and focus one dedicated home-workspace tab.
set -euo pipefail

usage() {
  printf 'usage: qq-herdr-home <inspect|focus-board|focus-architect> --repo <repository-path>\n' >&2
  exit 1
}

die() {
  printf 'qq-herdr-home: %s\n' "$*" >&2
  exit 1
}

self="$(readlink -f -- "${BASH_SOURCE[0]}")"
# shellcheck source=bin/lib/qq-bin.sh
source "$(dirname "$self")/lib/qq-bin.sh"

[ "$#" -eq 3 ] || usage
action="$1"
[ "$2" = "--repo" ] || usage
repo_arg="$3"
case "$action" in
  inspect | focus-board | focus-architect) ;;
  *) usage ;;
esac

qq_resolve_bin herdr || die "$QQ_BIN_ERROR"
HERDR="$QQ_BIN_RESULT"

command -v git >/dev/null 2>&1 || die "git not found"
command -v jq >/dev/null 2>&1 || die "jq not found"

repo_root="$(git -C "$repo_arg" rev-parse --show-toplevel 2>/dev/null)" \
  || die "not a Git checkout: $repo_arg"
worktrees="$(git -C "$repo_root" worktree list --porcelain 2>/dev/null)" \
  || die "cannot list Git worktrees for $repo_root"

main_paths=()
mapfile -t main_paths < <(
  awk '
    /^worktree / { path = substr($0, 10); next }
    /^branch refs\/heads\/main$/ { print path }
  ' <<<"$worktrees"
)
[ "${#main_paths[@]}" -eq 1 ] \
  || die "expected exactly one refs/heads/main checkout (found ${#main_paths[@]})"

main_checkout="$(cd "${main_paths[0]}" 2>/dev/null && pwd -P)" \
  || die "main checkout is unavailable: ${main_paths[0]}"
head_ref="$(git -C "$main_checkout" symbolic-ref -q HEAD 2>/dev/null)" \
  || die "main checkout has detached HEAD: $main_checkout"
[ "$head_ref" = "refs/heads/main" ] \
  || die "primary checkout is not on refs/heads/main: $main_checkout"

common_dir="$(git -C "$main_checkout" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)" \
  || die "cannot resolve Git common directory"
common_dir="$(readlink -f "$common_dir" 2>/dev/null)" \
  || die "cannot canonicalize Git common directory: $common_dir"

workspaces="$({ "$HERDR" workspace list 2>/dev/null || true; })"
jq -e '.result.workspaces | type == "array"' <<<"$workspaces" >/dev/null 2>&1 \
  || die "cannot inspect Herdr workspaces"

homes=()
mapfile -t homes < <(
  jq -r --arg checkout "$main_checkout" '
    .result.workspaces[]
    | select(
        .worktree != null
        and .worktree.checkout_path == $checkout
        and .worktree.is_linked_worktree == false
      )
    | [.workspace_id, .worktree.repo_key] | @tsv
  ' <<<"$workspaces"
)
[ "${#homes[@]}" -eq 1 ] \
  || die "expected exactly one persistent Herdr home for $main_checkout (found ${#homes[@]})"

IFS=$'\t' read -r home_workspace home_repo_key <<<"${homes[0]}"
if [ -z "$home_workspace" ] || [ -z "$home_repo_key" ]; then
  die "home workspace metadata is incomplete"
fi
canonical_repo_key="$(readlink -f "$home_repo_key" 2>/dev/null)" \
  || die "cannot canonicalize Herdr repo key: $home_repo_key"
[ "$canonical_repo_key" = "$common_dir" ] \
  || die "home workspace repo key does not match Git common directory"

focused=false
if [ "$action" = "focus-board" ]; then
  panes="$({ "$HERDR" pane list --workspace "$home_workspace" 2>/dev/null || true; })"
  jq -e '.result.panes | type == "array"' <<<"$panes" >/dev/null 2>&1 \
    || die "cannot inspect home workspace panes"

  board_panes=()
  while IFS=$'\t' read -r pane_id tab_id; do
    if [ -z "$pane_id" ] || [ -z "$tab_id" ]; then
      die "home workspace contains incomplete pane metadata"
    fi
    process_info="$({ "$HERDR" pane process-info --pane "$pane_id" 2>/dev/null || true; })"
    jq -e '.result.process_info.foreground_processes | type == "array"' \
      <<<"$process_info" >/dev/null 2>&1 \
      || die "cannot inspect home pane process: $pane_id"
    if jq -e '
      (.result.process_info.foreground_processes // [])
      | any(.[]?;
          (.argv? | type == "array")
          and ((.argv | length) >= 2)
          and (.argv[-1] == "board")
          and any(.argv[]; ((tostring | split("/") | last) == "backlog"))
        )
    ' <<<"$process_info" >/dev/null; then
      board_panes+=("$pane_id"$'\t'"$tab_id")
    fi
  done < <(jq -r '.result.panes[] | [.pane_id, .tab_id] | @tsv' <<<"$panes")

  [ "${#board_panes[@]}" -eq 1 ] \
    || die "expected exactly one Backlog-board pane in home workspace $home_workspace (found ${#board_panes[@]})"
  IFS=$'\t' read -r board_pane board_tab <<<"${board_panes[0]}"

  board_tab_panes="$(jq -r --arg tab "$board_tab" \
    '[.result.panes[] | select(.tab_id == $tab)] | length' <<<"$panes")"
  [ "$board_tab_panes" -eq 1 ] \
    || die "Backlog board tab $board_tab must contain exactly one pane (found $board_tab_panes)"

  "$HERDR" tab focus "$board_tab" >/dev/null 2>&1 \
    || die "could not focus Backlog board tab $board_tab"
  tab_info="$({ "$HERDR" tab get "$board_tab" 2>/dev/null || true; })"
  jq -e --arg tab "$board_tab" --arg workspace "$home_workspace" '
    .result.tab.tab_id == $tab
    and .result.tab.workspace_id == $workspace
    and .result.tab.focused == true
  ' <<<"$tab_info" >/dev/null 2>&1 \
    || die "Backlog board focus was not confirmed"
  focused=true
elif [ "$action" = "focus-architect" ]; then
  tabs="$({ "$HERDR" tab list --workspace "$home_workspace" 2>/dev/null || true; })"
  jq -e '.result.tabs | type == "array"' <<<"$tabs" >/dev/null 2>&1 \
    || die "cannot inspect home workspace tabs"

  architect_tabs=()
  mapfile -t architect_tabs < <(
    jq -r --arg workspace "$home_workspace" '
      .result.tabs[]
      | select(.workspace_id == $workspace and .label == "architect")
      | [.tab_id, .pane_count] | @tsv
    ' <<<"$tabs"
  )
  [ "${#architect_tabs[@]}" -eq 1 ] \
    || die "expected exactly one architect tab in home workspace $home_workspace (found ${#architect_tabs[@]})"
  IFS=$'\t' read -r architect_tab architect_pane_count <<<"${architect_tabs[0]}"
  if [ -z "$architect_tab" ] \
    || ! [[ "$architect_pane_count" =~ ^[0-9]+$ ]]; then
    die "architect tab metadata is incomplete"
  fi
  [ "$architect_pane_count" -eq 1 ] \
    || die "architect tab $architect_tab must contain exactly one pane (found $architect_pane_count)"

  "$HERDR" tab focus "$architect_tab" >/dev/null 2>&1 \
    || die "could not focus architect tab $architect_tab"
  tab_info="$({ "$HERDR" tab get "$architect_tab" 2>/dev/null || true; })"
  jq -e --arg tab "$architect_tab" --arg workspace "$home_workspace" '
    .result.tab.tab_id == $tab
    and .result.tab.workspace_id == $workspace
    and .result.tab.focused == true
  ' <<<"$tab_info" >/dev/null 2>&1 \
    || die "architect tab focus was not confirmed"
  focused=true
fi

jq -cn \
  --arg action "$action" \
  --arg repo_root "$repo_root" \
  --arg main_checkout "$main_checkout" \
  --arg home_workspace_id "$home_workspace" \
  --arg board_tab_id "${board_tab-}" \
  --arg board_pane_id "${board_pane-}" \
  --arg architect_tab_id "${architect_tab-}" \
  --argjson focused "$focused" \
  '{
    action: $action,
    repo_root: $repo_root,
    main_checkout: $main_checkout,
    home_workspace_id: $home_workspace_id,
    focused: $focused
  }
  + if $action == "focus-board" then {
      board_tab_id: $board_tab_id,
      board_pane_id: $board_pane_id
    } elif $action == "focus-architect" then {
      architect_tab_id: $architect_tab_id
    } else {} end'
