#!/usr/bin/env bash
# qq-wip — inspect / recover the working-tree savepoints taken by qq-wip-snapshot.sh.
#
#   qq-wip list            snapshots for the current branch, newest first
#   qq-wip diff            what the latest snapshot holds over HEAD
#   qq-wip branch <name>   materialize the latest snapshot as a real branch to inspect
#
# Recovery is always non-destructive: `branch` gives you the lost work on a fresh
# branch to cherry-pick or copy from — it never overwrites your working tree.
set -euo pipefail

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "not a git repo"; exit 1; }
branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo detached)
ref="refs/wip/${branch}"
git rev-parse --quiet --verify "$ref" >/dev/null 2>&1 \
  || { echo "no snapshots on '${branch}' (ref ${ref})"; exit 0; }

case "${1:-list}" in
  list)   git log --format='%h  %cd  %s' --date=iso "$ref" | head -50 ;;
  diff)   git --no-pager diff HEAD "$ref" ;;
  branch) [ -n "${2:-}" ] || { echo "usage: qq-wip branch <name>"; exit 1; }
          git branch "$2" "$ref" \
            && echo "snapshot → branch '${2}'. Inspect it, take what you need, then delete." ;;
  *)      echo "usage: qq-wip {list|diff|branch <name>}"; exit 1 ;;
esac
