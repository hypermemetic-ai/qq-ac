#!/usr/bin/env bash
# qq OpenWiki refresh — the gate's `commands.format`. Format runs before the
# gate's push step commits agent fixes, so a refresh here rides the landing
# transaction: `openwiki/` is updated by the same PR that changes the code,
# instead of drifting until a cron catches up.
# Guarded: a repo without openwiki/ (or a machine without the CLI / a real
# API key) is a fast no-op, and refresh failure warns rather than blocks —
# descriptive docs (layer 3) tolerate drift; the registry (layer 2) does not.
set -euo pipefail

say() { printf '[qq-openwiki-refresh] %s\n' "$1"; }

if [ ! -d openwiki ]; then
  say "no openwiki/ directory — wiki not adopted here; skipping."
  exit 0
fi

if ! command -v openwiki >/dev/null 2>&1; then
  say "WARNING: openwiki/ exists but the openwiki CLI is not installed; skipping refresh."
  exit 0
fi

env_file="$HOME/.openwiki/.env"
if [ ! -f "$env_file" ] || grep -qs "PASTE_KEY_HERE" "$env_file"; then
  say "WARNING: ~/.openwiki/.env missing or still holds the placeholder key; skipping refresh."
  exit 0
fi

say "refreshing openwiki/ against this diff (timeout 10m)..."
if timeout 600 openwiki --update </dev/null; then
  say "refresh complete."
else
  say "WARNING: openwiki --update failed or timed out; landing proceeds with stale descriptive docs."
fi
exit 0
