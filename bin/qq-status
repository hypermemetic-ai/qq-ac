#!/usr/bin/env bash
# Publish one delegate stage boundary to the detail file and Herdr glass.
# shellcheck disable=SC1091,SC2016
set -euo pipefail

self="$(readlink -f -- "${BASH_SOURCE[0]}")"
# shellcheck source=bin/lib/qq-bin.sh
source "$(dirname "$self")/lib/qq-bin.sh"
# shellcheck source=bin/lib/qq-engine.sh
source "$(dirname "$self")/lib/qq-engine.sh"

qq_engine_init qq-status status

mode=publish
if [ "${1:-}" = inspect ]; then
  mode=inspect
  shift
fi
event="${1:-}"
[ -n "$event" ] || qq_engine_error \
  'usage: qq-status [inspect] <queued|dispatched|working|envelope-received|envelope-verified|review|pr-open|blocked|failed|terminal> --repo <path> --dispatcher-workspace <id> --work-session <id> --pane <id> --agent <label> --ticket <id> --label <text> [details] [--dry-run]'
shift

repo=""
dispatcher_workspace=""
work_session=""
pane=""
agent=""
ticket=""
label=""
runtime=unavailable
handle=unavailable
events_path=unavailable
stderr_path=unavailable
checks=unavailable
pr_number=""
pr_url=""
final_checks=unavailable
reason=""
round=""
boundary_time=""
dry_run=false

while [ "$#" -gt 0 ]; do
  case "$1" in
    --repo)
      [ "$#" -ge 2 ] || qq_engine_error '--repo requires a path'
      repo="$2"
      shift 2
      ;;
    --dispatcher-workspace)
      [ "$#" -ge 2 ] || qq_engine_error '--dispatcher-workspace requires an id'
      dispatcher_workspace="$2"
      shift 2
      ;;
    --work-session)
      [ "$#" -ge 2 ] || qq_engine_error '--work-session requires an id'
      work_session="$2"
      shift 2
      ;;
    --pane)
      [ "$#" -ge 2 ] || qq_engine_error '--pane requires an id'
      pane="$2"
      shift 2
      ;;
    --agent)
      [ "$#" -ge 2 ] || qq_engine_error '--agent requires a label'
      agent="$2"
      shift 2
      ;;
    --ticket)
      [ "$#" -ge 2 ] || qq_engine_error '--ticket requires an id'
      ticket="$2"
      shift 2
      ;;
    --label)
      [ "$#" -ge 2 ] || qq_engine_error '--label requires text'
      label="$2"
      shift 2
      ;;
    --runtime)
      [ "$#" -ge 2 ] || qq_engine_error '--runtime requires a value'
      runtime="$2"
      shift 2
      ;;
    --handle)
      [ "$#" -ge 2 ] || qq_engine_error '--handle requires a value'
      handle="$2"
      shift 2
      ;;
    --events)
      [ "$#" -ge 2 ] || qq_engine_error '--events requires a path or unavailable'
      events_path="$2"
      shift 2
      ;;
    --stderr)
      [ "$#" -ge 2 ] || qq_engine_error '--stderr requires a path or unavailable'
      stderr_path="$2"
      shift 2
      ;;
    --checks)
      [ "$#" -ge 2 ] || qq_engine_error '--checks requires a summary'
      checks="$2"
      shift 2
      ;;
    --pr)
      [ "$#" -ge 2 ] || qq_engine_error '--pr requires a number'
      pr_number="$2"
      shift 2
      ;;
    --url)
      [ "$#" -ge 2 ] || qq_engine_error '--url requires a value'
      pr_url="$2"
      shift 2
      ;;
    --final-checks)
      [ "$#" -ge 2 ] || qq_engine_error '--final-checks requires a summary'
      final_checks="$2"
      shift 2
      ;;
    --reason)
      [ "$#" -ge 2 ] || qq_engine_error '--reason requires text'
      reason="$2"
      shift 2
      ;;
    --round)
      [ "$#" -ge 2 ] || qq_engine_error '--round requires a positive integer'
      round="$2"
      shift 2
      ;;
    --at)
      [ "$#" -ge 2 ] || qq_engine_error '--at requires a timestamp'
      boundary_time="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    *) qq_engine_error "unknown qq-status argument: $1" ;;
  esac
done

qq_engine_set_action "$mode:$event"

for required_name in repo dispatcher_workspace work_session pane agent ticket label; do
  [ -n "${!required_name}" ] \
    || qq_engine_error "--${required_name//_/-} is required"
done
[[ "$dispatcher_workspace" =~ ^[A-Za-z0-9._:-]+$ ]] \
  || qq_engine_error '--dispatcher-workspace contains unsafe path characters'
[[ "$agent" =~ ^[A-Za-z0-9._-]+$ ]] \
  || qq_engine_error '--agent must match [A-Za-z0-9._-]+'
for single_line in "$work_session" "$pane" "$ticket" "$label" "$runtime" "$handle"; do
  [[ "$single_line" != *$'\n'* && "$single_line" != *$'\r'* ]] \
    || qq_engine_error 'status identity and summary values must be single-line text'
done

case "$event" in
  queued)
    stage=queued
    agent_state=idle
    report_presence=false
    ;;
  dispatched)
    stage=dispatched
    agent_state=working
    report_presence=true
    ;;
  working)
    if [ -n "$round" ]; then
      [[ "$round" =~ ^[1-9][0-9]*$ ]] \
        || qq_engine_error '--round must be a positive integer'
      stage="working round $round"
    else
      stage=working
    fi
    agent_state=working
    report_presence=true
    ;;
  envelope-received)
    stage='envelope received'
    agent_state=idle
    report_presence=true
    ;;
  envelope-verified)
    stage='envelope verified'
    agent_state=idle
    report_presence=true
    ;;
  review)
    [[ "$round" =~ ^[1-9][0-9]*$ ]] \
      || qq_engine_error 'review requires --round <positive-integer>'
    stage="review round $round"
    agent_state=idle
    report_presence=true
    ;;
  pr-open)
    [ -n "$pr_number" ] || qq_engine_error 'pr-open requires --pr <number>'
    stage="PR #$pr_number open"
    agent_state=idle
    report_presence=true
    ;;
  blocked)
    [ -n "$reason" ] || qq_engine_error 'blocked requires --reason <text>'
    stage="BLOCKED: ${reason:0:60}"
    agent_state=blocked
    report_presence=true
    ;;
  failed)
    [ -n "$reason" ] || qq_engine_error 'failed requires --reason <text>'
    stage="FAILED: ${reason:0:60}"
    agent_state=blocked
    report_presence=true
    ;;
  terminal)
    stage=terminal
    agent_state=idle
    report_presence=false
    ;;
  *) qq_engine_error "unsupported status event: $event" ;;
esac

boundary_time="${boundary_time:-$(date -u +'%Y-%m-%dT%H:%M:%SZ')}"
if ! qq_resolve_bin git; then
  qq_engine_error "$QQ_BIN_ERROR"
fi
git_bin="$QQ_BIN_RESULT"
common_dir="$({ "$git_bin" -C "$repo" rev-parse --path-format=absolute --git-common-dir 2>/dev/null || true; })"
[ -n "$common_dir" ] || qq_engine_error "not a Git checkout: $repo"
repo_root="$(cd "$(dirname "$common_dir")" 2>/dev/null && pwd -P)" \
  || qq_engine_error "cannot resolve Repository root from: $repo"
status_base="${TMPDIR:-/tmp}/qq-delegates"
status_dir="$status_base$repo_root"
status_file="$status_dir/$dispatcher_workspace.status"
canonical_status_base="$(readlink -m -- "$status_base" 2>/dev/null || true)"
resolved_status_dir="$(readlink -m -- "$status_dir" 2>/dev/null || true)"
if [ -z "$canonical_status_base" ] || [ -z "$resolved_status_dir" ]; then
  qq_engine_error 'cannot resolve the derived status path'
fi
expected_status_dir="$canonical_status_base$repo_root"

base_state="$("$QQ_ENGINE_JQ" -cn \
  --arg event "$event" \
  --arg stage "$stage" \
  --arg repo_root "$repo_root" \
  --arg status_file "$status_file" \
  --arg dispatcher_workspace "$dispatcher_workspace" \
  --arg work_session "$work_session" \
  --arg pane "$pane" \
  --arg agent "$agent" \
  '{
    event:$event,
    stage:$stage,
    repo_root:$repo_root,
    status_file:$status_file,
    dispatcher_workspace:$dispatcher_workspace,
    work_session:$work_session,
    pane:$pane,
    agent:$agent
  }')"

if [ -L "$status_base" ] || [ "$resolved_status_dir" != "$expected_status_dir" ]; then
  state="$("$QQ_ENGINE_JQ" -cn --argjson base "$base_state" \
    '$base + {current_state:"status path contains an intermediate symlink"}')"
  qq_engine_refuse \
    'The derived status path contains an intermediate symlink. Leave it untouched and resolve the unexpected filesystem state; visibility glass never justifies overwriting an unexplained object.' \
    "$state"
fi
if [ -L "$status_dir" ] || { [ -e "$status_dir" ] && [ ! -d "$status_dir" ]; }; then
  state="$("$QQ_ENGINE_JQ" -cn --argjson base "$base_state" \
    '$base + {current_state:"status directory is not a real directory"}')"
  qq_engine_refuse \
    'The derived status directory is not a real directory. Leave it untouched, resolve the unexpected filesystem state, and retry; the engine will not follow a replacement link.' \
    "$state"
fi
if [ -L "$status_file" ] || { [ -e "$status_file" ] && [ ! -f "$status_file" ]; }; then
  state="$("$QQ_ENGINE_JQ" -cn --argjson base "$base_state" \
    '$base + {current_state:"status file is not a regular file"}')"
  qq_engine_refuse \
    'The derived status file is not a regular file. Leave it untouched, resolve the unexpected filesystem state, and retry; visibility glass never justifies overwriting an unexplained object.' \
    "$state"
fi

if [ "$mode" = inspect ] || [ "$dry_run" = true ]; then
  qq_engine_done 'status transition inspected; no detail file or Herdr state was changed' "$base_state"
fi

notes=()
detail_written=false
if ! mkdir -p "$status_dir" 2>/dev/null; then
  notes+=('detail file unavailable: could not create the derived status directory')
else
  temporary="$(mktemp "$status_dir/.$dispatcher_workspace.status.XXXXXX" 2>/dev/null || true)"
  if [ -z "$temporary" ]; then
    notes+=('detail file unavailable: could not create an atomic temporary file')
  else
    write_ok=true
    if [ -f "$status_file" ]; then
      if ! awk \
        -v begin="--- qq-delegate:$agent ---" \
        -v end="--- /qq-delegate:$agent ---" '
          $0 == begin { skipping = 1; next }
          $0 == end { skipping = 0; next }
          !skipping { print }
        ' "$status_file" >"$temporary"; then
        write_ok=false
      fi
    fi
    if [ "$write_ok" = true ] && [ "$event" != terminal ]; then
      temporary_has_content=false
      if [ -s "$temporary" ]; then
        temporary_has_content=true
      fi
      {
        if [ "$temporary_has_content" = true ]; then
          printf '\n'
        fi
        printf '%s\n' "--- qq-delegate:$agent ---"
        printf 'ticket: %s\n' "$ticket"
        printf 'label: %s\n' "$label"
        printf 'stage: %s since %s\n' "$stage" "$boundary_time"
        printf 'runtime: %s\n' "$runtime"
        printf 'steering: %s\n' "$handle"
        printf 'events: %s\n' "$events_path"
        printf 'stderr: %s\n' "$stderr_path"
        if [ -n "$reason" ]; then
          printf 'reason: %s\n' "$reason"
        fi
        printf 'envelope checks: %s\n' "$checks"
        if [ -n "$pr_number" ] || [ -n "$pr_url" ]; then
          printf 'pull request: #%s %s\n' "$pr_number" "$pr_url"
        fi
        printf 'final checks: %s\n' "$final_checks"
        printf '%s\n' "--- /qq-delegate:$agent ---"
      } >>"$temporary" || write_ok=false
    fi
    if [ "$write_ok" = true ] \
      && mv -f -- "$temporary" "$status_file" 2>/dev/null; then
      resolved_written_status_dir="$(realpath -- "$status_dir" 2>/dev/null || true)"
      # Full mid-flight TOCTOU prevention is out of scope for a non-gating Bash
      # glass engine; this outcome guard prevents a redirected write persisting.
      if [ "$resolved_written_status_dir" != "$expected_status_dir" ]; then
        rm -f -- "$status_file" 2>/dev/null || true
        state="$("$QQ_ENGINE_JQ" -cn --argjson base "$base_state" \
          '$base + {current_state:"status write escaped through an intermediate symlink"}')"
        qq_engine_refuse \
          'The derived status path contains an intermediate symlink. Leave it untouched and resolve the unexpected filesystem state; visibility glass never justifies overwriting an unexplained object.' \
          "$state"
      fi
      detail_written=true
    else
      rm -f -- "$temporary"
      notes+=('detail file unavailable: atomic rewrite failed')
    fi
  fi
fi

herdr_available=true
if ! qq_resolve_bin herdr; then
  herdr_available=false
  notes+=('herdr unavailable: Herdr reporting was a no-op; continue from the detail file and transcript')
else
  herdr_bin="$QQ_BIN_RESULT"
fi

last_sequence=0
sequences=()
herdr_failure_noted=false
next_sequence() {
  local now
  now="$(date +%s)"
  if [ "$now" -le "$last_sequence" ]; then
    now=$((last_sequence + 1))
  fi
  last_sequence="$now"
  NEXT_SEQUENCE="$now"
  sequences+=("$now")
}

note_herdr_failure() {
  if [ "$herdr_failure_noted" = false ]; then
    notes+=('herdr call failed: Herdr reporting degraded; continue from the detail file and transcript')
    herdr_failure_noted=true
  fi
}

if [ "$herdr_available" = true ]; then
  if [ "$event" = terminal ]; then
    next_sequence
    "$herdr_bin" workspace report-metadata "$work_session" \
      --source qq-dispatch --clear-token stage --seq "$NEXT_SEQUENCE" \
      >/dev/null 2>&1 || note_herdr_failure
    next_sequence
    "$herdr_bin" pane release-agent "$pane" \
      --source qq-dispatch --agent "$agent" --seq "$NEXT_SEQUENCE" \
      >/dev/null 2>&1 || note_herdr_failure
  else
    next_sequence
    "$herdr_bin" workspace report-metadata "$work_session" \
      --source qq-dispatch --token "stage=$stage" \
      --seq "$NEXT_SEQUENCE" --ttl-ms 7200000 \
      >/dev/null 2>&1 || note_herdr_failure
    if [ "$report_presence" = true ]; then
      next_sequence
      "$herdr_bin" pane report-agent "$pane" \
        --source qq-dispatch --agent "$agent" --state "$agent_state" \
        --message "$stage" --seq "$NEXT_SEQUENCE" \
        >/dev/null 2>&1 || note_herdr_failure
    fi
    if [ "$event" = blocked ] || [ "$event" = failed ]; then
      notification_result="$({ "$herdr_bin" notification show \
        "$ticket needs attention" --body "$reason" --sound request \
        2>/dev/null || true; })"
      if ! "$QQ_ENGINE_JQ" -e '.result.shown == true' \
        <<<"$notification_result" >/dev/null 2>&1; then
        note_herdr_failure
      fi
    fi
  fi
fi

notes_json='[]'
for note in "${notes[@]}"; do
  notes_json="$("$QQ_ENGINE_JQ" -cn --argjson notes "$notes_json" --arg note "$note" \
    '$notes + [$note]')"
done
sequences_json='[]'
for sequence in "${sequences[@]}"; do
  sequences_json="$("$QQ_ENGINE_JQ" -cn --argjson sequences "$sequences_json" \
    --argjson sequence "$sequence" '$sequences + [$sequence]')"
done
state="$("$QQ_ENGINE_JQ" -cn \
  --argjson base "$base_state" \
  --argjson detail_written "$detail_written" \
  --argjson herdr_available "$herdr_available" \
  --argjson sequences "$sequences_json" \
  --argjson notes "$notes_json" \
  '$base + {
    detail_written:$detail_written,
    herdr_available:$herdr_available,
    sequences:$sequences,
    notes:$notes,
    degraded:(($notes | length) > 0)
  }')"

if [ "${#notes[@]}" -gt 0 ]; then
  qq_engine_done 'status transition completed with best-effort visibility degradation; see notes' "$state"
fi
qq_engine_done 'status transition published to the detail file and Herdr' "$state"
