#!/usr/bin/env bash
# qq-herdr-pull — replace a herdr placeholder pane with an agent pane.
#
# Operator mode is the mirror of focus_agent (prefix+alt+N, "go to agent N"):
# instead of jumping to the agent, it brings the selected agent to the focused
# pane. This mode is bound as a detached custom key, so failures are best-effort
# notifications and the command exits successfully.
#
# Agent mode lets an accountable agent adopt a freshly created Change
# workspace. It moves the calling agent into that workspace and replaces its
# sole idle shell pane. This mode is fail-fast because delivery automation must
# be able to stop before it edits the wrong checkout.
#
# herdr's `pane swap` is within-tab only (it refuses cross-tab with reason
# "cross_tab"), so both modes share `pane move` + `pane close`.
#
#   qq-herdr-pull <N>                  operator: pull agent N to the focused pane
#   qq-herdr-pull next                 operator: pull the highest-priority agent
#   qq-herdr-pull --workspace <id>     agent: adopt a pristine workspace
#
# Selection order for operator mode follows `herdr agent list`, which is the
# order the sidebar renders. Number N is 1-based and counts every agent,
# including the focused pane; pulling yourself is a safe no-op.
set -euo pipefail

mode="operator"
sel="${1:-}"
workspace=""
if [ "$sel" = "--workspace" ]; then
  mode="agent"
  workspace="${2:-}"
  if [ "$#" -ne 2 ] || [ -z "$workspace" ]; then
    printf 'qq-herdr-pull: usage: qq-herdr-pull --workspace <workspace-id>\n' >&2
    exit 1
  fi
elif [ "$#" -ne 1 ]; then
  sel=""
fi

# Resolve the herdr binary: env hint, PATH, then the known Homebrew location.
if [ -n "${HERDR_BIN_PATH:-}" ] && [ -x "${HERDR_BIN_PATH}" ]; then
  HERDR="${HERDR_BIN_PATH}"
elif command -v herdr >/dev/null 2>&1; then
  HERDR="herdr"
elif [ -x /home/linuxbrew/.linuxbrew/bin/herdr ]; then
  HERDR="/home/linuxbrew/.linuxbrew/bin/herdr"
else
  printf 'qq-herdr-pull: herdr not found\n' >&2
  [ "$mode" = "operator" ] && exit 0
  exit 1
fi

note() { "$HERDR" notification show "qq-pull" --body "$1" >/dev/null 2>&1 || true; }
die() {
  if [ "$mode" = "operator" ]; then
    note "$1"
    exit 0
  fi
  printf 'qq-herdr-pull: %s\n' "$1" >&2
  exit 1
}

command -v jq >/dev/null 2>&1 || die "jq not found — required by qq-herdr-pull"

source=""
target=""
target_tab=""

if [ "$mode" = "agent" ]; then
  # Query first: HERDR_PANE_ID is injected when a pane starts and can retain its
  # old public id after a cross-workspace move. `pane current --current`
  # resolves the calling terminal to its live pane id.
  current="$({ "$HERDR" pane current --current 2>/dev/null || true; })"
  source="$(jq -r '.result.pane.pane_id // empty' <<<"$current" 2>/dev/null)" || true
  [ -n "$source" ] || die "cannot resolve calling agent pane"
  source_agent="$(jq -r '.result.pane.agent // empty' <<<"$current" 2>/dev/null)" || true
  [ -n "$source_agent" ] || die "calling pane '$source' is not an agent"

  current_workspace="$(jq -r '.result.pane.workspace_id // empty' <<<"$current" 2>/dev/null)" || true
  if [ "$current_workspace" = "$workspace" ]; then
    printf 'workspace=%s pane=%s changed=false\n' "$workspace" "$source"
    exit 0
  fi

  workspace_info="$({ "$HERDR" workspace get "$workspace" 2>/dev/null || true; })"
  resolved_workspace="$(jq -r '.result.workspace.workspace_id // empty' \
    <<<"$workspace_info" 2>/dev/null)" || true
  [ "$resolved_workspace" = "$workspace" ] || die "workspace '$workspace' not found"

  panes="$({ "$HERDR" pane list --workspace "$workspace" 2>/dev/null || true; })"
  pane_count="$(jq -r '.result.panes | length // 0' <<<"$panes" 2>/dev/null)" || true
  [ -n "$pane_count" ] || die "cannot inspect workspace '$workspace' panes"
  [ "$pane_count" = "1" ] \
    || die "workspace '$workspace' must contain exactly one placeholder pane (found $pane_count)"

  target="$(jq -r '.result.panes[0].pane_id // empty' <<<"$panes" 2>/dev/null)" || true
  target_tab="$(jq -r '.result.panes[0].tab_id // empty' <<<"$panes" 2>/dev/null)" || true
  target_agent="$(jq -r '.result.panes[0].agent // empty' <<<"$panes" 2>/dev/null)" || true
  if [ -z "$target" ] || [ -z "$target_tab" ]; then
    die "cannot resolve workspace placeholder"
  fi
  [ -z "$target_agent" ] || die "workspace '$workspace' is already occupied by an agent"

  process_info="$({ "$HERDR" pane process-info --pane "$target" 2>/dev/null || true; })"
  jq -e '
    .result.process_info as $p
    | ($p.shell_pid != null)
      and ($p.foreground_process_group_id == $p.shell_pid)
      and (($p.foreground_processes | length) == 1)
      and ($p.foreground_processes[0].pid == $p.shell_pid)
  ' <<<"$process_info" >/dev/null \
    || die "workspace '$workspace' pane '$target' is not an idle shell placeholder"
else
  [ -n "$sel" ] || die "usage: qq-herdr-pull <N|next>"

  # Detached keybindings receive the pane where the key was pressed. Fall back
  # to the focused pane when invoked manually without the injected identity.
  target="${HERDR_PANE_ID:-}"
  if [ -z "$target" ]; then
    target="$({ "$HERDR" pane current --current 2>/dev/null || true; } \
      | jq -r '.result.pane.pane_id // empty' 2>/dev/null)" || true
  fi
  [ -n "$target" ] || die "cannot resolve focused pane"

  agents="$({ "$HERDR" agent list 2>/dev/null || true; })"
  agent_list_type="$(jq -r '.result.type // empty' <<<"$agents" 2>/dev/null)" || true
  [ -n "$agent_list_type" ] || die "herdr agent list failed"

  case "$sel" in
    next)
      source="$(jq -r --arg me "$target" '
        [.result.agents[] | select(.pane_id != $me)]
        | sort_by(
            if   .agent_status == "blocked" then 0
            elif .agent_status == "working" then 1
            elif .agent_status == "idle"    then 2
            else 3 end)
        | .[0].pane_id // empty' <<<"$agents" 2>/dev/null)" || true
      ;;
    *[!0-9]* | "")
      die "usage: qq-herdr-pull <N|next>"
      ;;
    *)
      # jq index -1 means the last element, so reject zero explicitly.
      if [ "$sel" -lt 1 ]; then
        die "agent number must be 1 or higher (got '$sel')"
      fi
      source="$(jq -r --argjson n "$sel" '.result.agents[$n-1].pane_id // empty' \
        <<<"$agents" 2>/dev/null)" || true
      ;;
  esac

  [ -n "$source" ] || die "no agent for '$sel'"

  if [ "$source" = "$target" ]; then
    note "#$sel is already your pane"
    exit 0
  fi

  target_tab="$({ "$HERDR" pane get "$target" 2>/dev/null || true; } \
    | jq -r '.result.pane.tab_id // empty' 2>/dev/null)" || true
  [ -n "$target_tab" ] || die "cannot resolve focused tab"
fi

# Dry run reports the fully validated pair and stops before layout mutation.
if [ -n "${QQ_HERDR_PULL_DRY:-}" ]; then
  if [ "$mode" = "agent" ]; then
    printf 'workspace=%s target=%s source=%s\n' "$workspace" "$target" "$source"
  else
    printf 'target=%s source=%s\n' "$target" "$source"
  fi
  exit 0
fi

# Move first. A move failure leaves both the source and placeholder intact.
move_result="$({
  "$HERDR" pane move "$source" --tab "$target_tab" --target-pane "$target" \
    --split right --focus 2>/dev/null
})" || die "move failed ($source -> $target_tab)"

move_changed="$(jq -r '.result.move_result.changed // false' \
  <<<"$move_result" 2>/dev/null)" || true
move_reason="$(jq -r '.result.move_result.reason // "unknown"' \
  <<<"$move_result" 2>/dev/null)" || true
if [ "$move_changed" != "true" ]; then
  die "move not applied ($source -> $target_tab; reason: ${move_reason:-unknown})"
fi

moved_pane="$(jq -r '.result.move_result.pane.pane_id // empty' \
  <<<"$move_result" 2>/dev/null)" || true
[ -n "$moved_pane" ] || die "move succeeded without a returned pane id; placeholder '$target' remains"

# Close only after Herdr confirms the agent moved. A close failure is visible to
# automation and preserves both panes for recovery.
if ! "$HERDR" pane close "$target" >/dev/null 2>&1; then
  if [ "$mode" = "operator" ]; then
    note "agent moved in, but could not close old pane $target"
    exit 0
  fi
  die "agent moved to '$moved_pane', but placeholder '$target' could not be closed"
fi

if [ "$mode" = "agent" ]; then
  printf 'workspace=%s pane=%s replaced=%s changed=true\n' \
    "$workspace" "$moved_pane" "$target"
fi
