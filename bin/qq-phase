#!/usr/bin/env bash
# qq-phase — stamp the current background-work phase to .qq/state.json, a cheap,
# token-free source of truth a status widget reads. Multi-producer: each
# long-running skill (orchestrate's loop, /idea's researcher, …) stamps its own
# slot under producers{} — keyed by --producer, default "main" — so concurrent
# producers never clobber each other and one producer's `done` never resets
# another's state. Writes are serialized with a lock and land atomically.
# Never makes an LLM call — pure local file + a fast local-daemon read for the
# gate run id.
#
#   qq-phase <Phase> [--producer P] [--detail T] [--task T] [--status S] [--gate]
#                                    advance to a phase
#   qq-phase gate [--producer P]     attach the active gate run id (no phase change)
#   qq-phase status                  print the current state JSON (raw read API)
#   qq-phase render                  one-line status for the widget/statusline (silent when idle)
#   qq-phase done [--producer P]     mark the producer's work complete (status=done)
#   qq-phase clear [--producer P]    remove the producer's slot (bare: remove all state)
#
# Loop phases: Align(1) Plan(2) Build(3) Verify(4) Sign-off(5) Review(6) Compound(7);
# Triage(0) is pre-loop. Any other name (e.g. capturing/researching) stamps verbatim
# with a null index — so non-loop producers share the same surface.
set -euo pipefail

cmd="${1:-status}"; shift || true

# render — the reader half: a tolerant one-liner for the Claude Code statusline.
# NEVER errors and prints nothing when there's no active work / not a repo, so a
# blank cockpit stays blank. Touches the gate daemon only when a run is attached.
if [ "$cmd" = "render" ]; then
  root=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
  file="$root/.qq/state.json"
  [ -f "$file" ] || exit 0
  branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo detached)
  gate_out=""
  if grep -q '"gate_run_id"' "$file" 2>/dev/null; then
    gate_out=$( { timeout 2 no-mistakes axi status 2>/dev/null || true; } )
  fi
  BRANCH="$branch" FILE="$file" GATE_OUT="$gate_out" python3 - <<'PY'
import json, os
try:                                    # never error: a malformed state file renders as nothing,
    st = json.load(open(os.environ["FILE"]))   # same as the missing-file / not-a-repo cases
except Exception:
    raise SystemExit(0)
if not isinstance(st, dict):            # valid but non-object JSON (null/[]/…) → treat as no state
    raise SystemExit(0)

prods = st.get("producers")
if not isinstance(prods, dict) or not prods:
    # legacy single-slot shape: treat the top level as the "main" slot
    prods = {"main": st} if st.get("phase") else {}
prods = {n: s for n, s in prods.items() if isinstance(s, dict) and s.get("phase")}
if not prods:
    raise SystemExit(0)

# parse the gate daemon's status once; each slot matches its own run id below
lines = os.environ.get("GATE_OUT", "").splitlines()
run_id = run_status = run_outcome = step = gstatus = None
seen_block = False  # after steps[/gate:, a `status:` is no longer the run's own
for i, l in enumerate(lines):
    s = l.strip()
    if s.startswith("steps[") or s.startswith("gate:"):
        seen_block = True
    if run_id is None and s.startswith("id:"):
        run_id = s.split(":", 1)[1].strip().strip('"')
    elif run_status is None and not seen_block and s.startswith("status:"):
        run_status = s.split(":", 1)[1].strip().strip('"')
    if run_outcome is None and s.startswith("outcome:"):   # a finished run reports `outcome:`
        run_outcome = s.split(":", 1)[1].strip().strip('"')
    if s == "gate:":                              # nested: `gate:` then `  step: X`
        for j in range(i + 1, min(i + 8, len(lines))):
            t = lines[j].strip()
            if t.startswith("step:"):     step    = t.split(":", 1)[1].strip().strip('"')
            elif t.startswith("status:"): gstatus = t.split(":", 1)[1].strip().strip('"')
    elif s.startswith("gate:") and len(s) > 5:    # inline: `gate: review`
        step = s.split(":", 1)[1].strip().strip('"')
        for j in range(i + 1, min(i + 4, len(lines))):
            t = lines[j].strip()
            if t.startswith("status:"):
                gstatus = t.split(":", 1)[1].strip().strip('"'); break
terminal = {"passed", "completed", "succeeded", "failed", "blocked",
            "cancelled", "canceled", "error", "aborted",
            "checks-passed", "checks-failed"}
finished = run_outcome is not None or run_status in terminal

def order(item):                       # main first, then by age
    name, slot = item
    return (name != "main", slot.get("started_at") or 0, name)

segments = []
for name, slot in sorted(prods.items(), key=order):
    phase  = slot.get("phase", "idle")
    status = slot.get("status", "working")
    index  = slot.get("index")
    total  = slot.get("total", 7)
    icon = {"working": "◐", "green": "●", "red": "✗", "done": "✓"}.get(status, "◐")
    core = f"{icon} {phase} {index}/{total}" if index is not None else f"{icon} {phase}"
    if name != "main":
        core = f"{name}:{core}"
    if slot.get("detail"):
        core += f" · {slot['detail']}"
    # only advertise a gate step while the run is genuinely THIS slot's run and
    # still live; a finished run (terminal status OR any `outcome:` reported) or
    # another/unknown run never leaves a stale pending marker behind
    gid = slot.get("gate_run_id")
    if gid and run_id == gid and not finished:
        if step:
            core += f" · gate:{step}" + (" ⏳" if gstatus and "await" in gstatus else "")
        else:
            core += " · gate ⏳"
    segments.append(core)

branch = os.environ.get("BRANCH") or st.get("branch") or ""
joined = " ‖ ".join(segments)
print(f"{branch}  {joined}" if branch else joined)
PY
  exit 0
fi

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || { echo "not a git repo"; exit 1; }
root=$(git rev-parse --show-toplevel)
dir="$root/.qq"
file="$dir/state.json"
branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo detached)

detail=""; task=""; status=""; gate=0; phase=""; producer="main"; producer_set=0; clear=0
case "$cmd" in
  status) [ -f "$file" ] && cat "$file" || echo '{"phase":"idle"}'; exit 0 ;;
  clear)  clear=1; phase="__keep__" ;;
  gate)   gate=1; phase="__keep__" ;;
  done)   phase="__keep__"; status="done" ;;
  *)      phase="$cmd" ;;
esac

while [ $# -gt 0 ]; do
  case "$1" in
    --producer) producer="${2:-main}"; producer_set=1; shift 2 ;;
    --detail)   detail="${2:-}"; shift 2 ;;
    --task)     task="${2:-}";   shift 2 ;;
    --status)   status="${2:-}"; shift 2 ;;
    --gate)     gate=1; shift ;;
    *) echo "unknown arg: $1"; exit 1 ;;
  esac
done

# bare clear wipes the whole surface; clear --producer removes one slot below
if [ "$clear" = "1" ] && [ "$producer_set" = "0" ]; then
  rm -f "$file" "$file.lock"; echo "cleared $file"; exit 0
fi

gate_id=""
if [ "$gate" = "1" ]; then
  # same short timeout as render: a wedged/absent daemon must never hang a phase stamp
  gate_id=$( { timeout 2 no-mistakes axi status 2>/dev/null || true; } | grep -oE '[0-9A-Z]{26}' | head -1 || true)
fi

mkdir -p "$dir"
now=$(date +%s)

PHASE="$phase" DETAIL="$detail" TASK="$task" STATUS="$status" GATE="$gate" GATE_ID="$gate_id" \
PRODUCER="$producer" CLEAR="$clear" BRANCH="$branch" NOW="$now" FILE="$file" python3 - <<'PY'
import fcntl, json, os, tempfile

file = os.environ["FILE"]

# serialize read-modify-write across concurrent producers: without the lock two
# simultaneous stamps read the same base state and the loser's slot is silently
# dropped by the winner's atomic replace
lock = open(file + ".lock", "w")
fcntl.flock(lock, fcntl.LOCK_EX)

try:
    with open(file) as f: st = json.load(f)
except Exception:
    st = {}
if not isinstance(st, dict):    # non-object JSON (null/[]/…) → start clean, don't crash on .get()
    st = {}

# migrate the legacy single-slot shape: top-level phase fields become the "main" slot
if "producers" not in st and st.get("phase"):
    slot_keys = ("phase", "index", "total", "status", "detail", "task",
                 "started_at", "gate_run_id")
    st["producers"] = {"main": {k: st.pop(k) for k in slot_keys if k in st}}
producers = st.setdefault("producers", {})
if not isinstance(producers, dict):
    producers = st["producers"] = {}

prod = os.environ.get("PRODUCER") or "main"

if os.environ.get("CLEAR") == "1":
    producers.pop(prod, None)
    if not producers:
        if os.path.exists(file):
            os.unlink(file)
        print(json.dumps({"cleared": prod, "state": "empty"}))
        raise SystemExit(0)
    st["updated_at"] = int(os.environ["NOW"])
else:
    slot = producers.get(prod)
    if not isinstance(slot, dict):
        slot = {}

    names = ["Triage", "Align", "Plan", "Build", "Verify", "Sign-off", "Review", "Compound"]
    idx = {n.lower(): i for i, n in enumerate(names)}
    idx.update({"signoff": 5, "sign off": 5})
    canon = {n.lower(): n for n in names}

    phase = os.environ["PHASE"]
    if phase == "__keep__":
        phase = slot.get("phase", "idle")
    else:
        phase = canon.get(phase.lower(), phase)

    # a fresh run (no prior state, or the last one finished) starts clean —
    # per slot, so one producer finishing never resets another's state
    if not slot.get("started_at") or slot.get("status") == "done":
        slot = {"started_at": int(os.environ["NOW"])}

    # detail and status verdicts are phase-scoped: a phase change clears each unless
    # this call re-supplies it — green/red belong to the phase that was judged, so a
    # red Verify must not bleed its icon onto the repair phase that follows
    prev_phase = slot.get("phase")
    if phase != prev_phase:
        if not os.environ.get("DETAIL"):
            slot.pop("detail", None)
        if not os.environ.get("STATUS"):
            slot["status"] = "working"

    slot["phase"] = phase
    slot["index"] = idx.get(phase.lower())
    slot["total"] = 7
    slot["updated_at"] = int(os.environ["NOW"])

    for key, env in (("detail", "DETAIL"), ("task", "TASK"), ("status", "STATUS")):
        v = os.environ.get(env, "")
        if v:
            slot[key] = v

    # gate id: an attach (--gate/gate) stores a live run id in the producer's slot;
    # an attach that comes back empty (daemon timeout/absent, or no active run)
    # CLEARS any stale id so render stops polling the daemon. A call that does not
    # attach leaves the id untouched.
    if os.environ.get("GATE") == "1":
        live = os.environ.get("GATE_ID", "")
        if live:
            slot["gate_run_id"] = live
        else:
            slot.pop("gate_run_id", None)

    slot.setdefault("status", "working")

    # a finished run has no live gate step — drop the id so render shows no stale ⏳
    if slot.get("status") == "done":
        slot.pop("gate_run_id", None)

    producers[prod] = slot
    st["branch"] = os.environ["BRANCH"]
    st["updated_at"] = int(os.environ["NOW"])

tmp = tempfile.NamedTemporaryFile("w", dir=os.path.dirname(file), delete=False)
json.dump(st, tmp, indent=2)
tmp.write("\n")
tmp.close()
os.replace(tmp.name, file)
print(json.dumps(st))
PY
