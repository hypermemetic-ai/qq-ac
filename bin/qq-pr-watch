#!/usr/bin/env bash
# Wait for one pull request terminal disposition and emit one JSON wake.
# shellcheck disable=SC1091,SC2016
set -euo pipefail

self="$(readlink -f -- "${BASH_SOURCE[0]}")"
# shellcheck source=bin/lib/qq-bin.sh
source "$(dirname "$self")/lib/qq-bin.sh"
# shellcheck source=bin/lib/qq-engine.sh
source "$(dirname "$self")/lib/qq-engine.sh"

qq_engine_init qq-pr-watch watch

mode=watch
if [ "${1:-}" = inspect ]; then
  mode=inspect
  shift
fi
pr="${1:-}"
[ -n "$pr" ] || qq_engine_error \
  'usage: qq-pr-watch [inspect] <pull-request> [--interval <30-60>] [--dry-run]'
shift

interval=30
dry_run=false
while [ "$#" -gt 0 ]; do
  case "$1" in
    --interval)
      [ "$#" -ge 2 ] || qq_engine_error '--interval requires seconds'
      interval="$2"
      shift 2
      ;;
    --dry-run)
      dry_run=true
      shift
      ;;
    *) qq_engine_error "unknown qq-pr-watch argument: $1" ;;
  esac
done
qq_engine_set_action "$mode"

if ! [[ "$interval" =~ ^[0-9]+$ ]] \
  || [ "$interval" -lt 30 ] || [ "$interval" -gt 60 ]; then
  qq_engine_error '--interval must be an integer from 30 through 60 seconds'
fi
if ! qq_resolve_bin gh; then
  qq_engine_error "$QQ_BIN_ERROR"
fi
gh_bin="$QQ_BIN_RESULT"

read_pr() {
  local response
  if ! response="$("$gh_bin" pr view --json state,url -- "$pr" 2>/dev/null)"; then
    qq_engine_error \
      'GitHub pull-request inspection failed; no terminal notification was emitted.'
  fi
  if ! PR_STATE="$("$QQ_ENGINE_JQ" -er '.state | select(type == "string" and length > 0)' \
    <<<"$response" 2>/dev/null)"; then
    qq_engine_error \
      'GitHub did not return a readable pull-request state; no terminal notification was emitted.'
  fi
  PR_URL="$("$QQ_ENGINE_JQ" -r '.url // ""' <<<"$response" 2>/dev/null || true)"
}

read_pr
case "$PR_STATE" in
  MERGED | CLOSED) ;;
  OPEN) ;;
  *)
    state="$("$QQ_ENGINE_JQ" -cn --arg pr "$pr" --arg pr_state "$PR_STATE" \
      --arg url "$PR_URL" '{pull_request:$pr, pr_state:$pr_state, url:$url}')"
    qq_engine_error 'GitHub returned an unsupported pull-request state.' "$state"
    ;;
esac

if [ "$mode" = inspect ] || [ "$dry_run" = true ]; then
  state="$("$QQ_ENGINE_JQ" -cn --arg pr "$pr" --arg pr_state "$PR_STATE" \
    --arg url "$PR_URL" --argjson interval "$interval" \
    '{pull_request:$pr, pr_state:$pr_state, url:$url, interval_seconds:$interval, notification_count:0}')"
  if [ "$PR_STATE" = OPEN ]; then
    qq_engine_refuse \
      'The pull request is still OPEN; no completion notification was emitted. Leave the watch armed or retry after disposition.' \
      "$state"
  fi
  qq_engine_done \
    "pull request is already $PR_STATE; inspection emitted no completion notification" \
    "$state"
fi

while [ "$PR_STATE" = OPEN ]; do
  sleep "$interval"
  read_pr
  case "$PR_STATE" in
    OPEN | MERGED | CLOSED) ;;
    *)
      state="$("$QQ_ENGINE_JQ" -cn --arg pr "$pr" --arg pr_state "$PR_STATE" \
        --arg url "$PR_URL" '{pull_request:$pr, pr_state:$pr_state, url:$url}')"
      qq_engine_error 'GitHub returned an unsupported pull-request state.' "$state"
      ;;
  esac
done

state="$("$QQ_ENGINE_JQ" -cn --arg pr "$pr" --arg pr_state "$PR_STATE" \
  --arg url "$PR_URL" '{pull_request:$pr, pr_state:$pr_state, url:$url, notification_count:1}')"
qq_engine_done "pull request reached terminal state $PR_STATE" "$state"
