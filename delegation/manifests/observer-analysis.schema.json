{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "qq observer analysis",
  "oneOf": [
    { "$ref": "#/$defs/success" },
    { "$ref": "#/$defs/failure" }
  ],
  "$defs": {
    "success": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "schema_version",
        "run",
        "episodes",
        "dropped_signals",
        "limitations"
      ],
      "properties": {
        "schema": { "const": "qq-observer.analysis" },
        "schema_version": { "const": 1 },
        "run": {
          "type": "object",
          "additionalProperties": false,
          "required": ["change", "sessions"],
          "properties": {
            "change": { "type": "string", "minLength": 1 },
            "sessions": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "episodes": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/episode" }
        },
        "dropped_signals": {
          "type": "array",
          "items": { "$ref": "#/$defs/dropped_signal" }
        },
        "limitations": { "type": "string" }
      }
    },
    "failure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "schema_version", "status", "reason"],
      "properties": {
        "schema": { "const": "qq-observer.analysis" },
        "schema_version": { "const": 1 },
        "status": { "const": "analysis_failed" },
        "reason": { "type": "string" }
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "title",
        "sessions",
        "evidence",
        "what_happened",
        "root_cause",
        "root_cause_location",
        "cost",
        "remedy",
        "confidence",
        "confidence_why",
        "recurrence_key"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "tool-gap.capability-unknown",
            "tool-gap.tool-missing",
            "instruction-conflict",
            "instruction-deficiency",
            "tool-misuse",
            "friction",
            "waste",
            "failure",
            "substrate",
            "design-question"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "rank": { "type": "integer", "minimum": 1 },
        "sessions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/evidence" }
        },
        "what_happened": { "type": "string", "minLength": 1 },
        "root_cause": { "type": "string", "minLength": 1 },
        "root_cause_location": {
          "type": "string",
          "enum": [
            "work-order",
            "skill",
            "instruction",
            "tool",
            "agent-behavior",
            "substrate",
            "harness-design"
          ]
        },
        "cost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["turns", "tokens", "seconds", "source"],
          "properties": {
            "turns": { "type": "integer", "minimum": 0 },
            "tokens": { "type": "integer", "minimum": 0 },
            "seconds": { "type": "number", "minimum": 0 },
            "source": {
              "type": "string",
              "minLength": 1,
              "description": "The validator requires exactly facts:<sessions[0] path> and grounds all cost fields in supplied facts JSON."
            }
          }
        },
        "remedy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "smallest_change"],
          "properties": {
            "type": { "type": "string", "minLength": 1 },
            "smallest_change": { "type": "string", "minLength": 1 }
          }
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "confidence_why": { "type": "string" },
        "recurrence_key": { "type": "string", "minLength": 1 }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session", "entries", "quote"],
      "properties": {
        "session": { "type": "string" },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        },
        "quote": {
          "type": "string",
          "maxLength": 200,
          "description": "The validator additionally requires a non-empty whitespace-normalized verbatim substring of the cited entries' quotable text."
        }
      }
    },
    "dropped_signal": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "entries", "why"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        },
        "why": { "type": "string", "minLength": 1 }
      }
    }
  }
}
