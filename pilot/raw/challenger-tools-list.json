                "type": "string"
              },
              "directory": {
                "description": "Filter by directory path (e.g., 'src/utils', 'lib')",
                "type": "string"
              },
              "chunkType": {
                "description": "Filter by code chunk type",
                "type": "string",
                "enum": [
                  "function",
                  "class",
                  "method",
                  "interface",
                  "type",
                  "enum",
                  "struct",
                  "impl",
                  "trait",
                  "module",
                  "other"
                ]
              },
              "contextLines": {
                "description": "Number of extra lines to include before/after each match (default: 0)",
