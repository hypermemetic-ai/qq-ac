{
  "permissions": {
    "deny": [
      "Bash(gh pr merge:*)",
      "Bash(gh * pr merge)",
      "Bash(gh * pr merge *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/bin/qq-claude-backlog-hook",
            "args": []
          }
        ]
      }
    ]
  }
}
