<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="prevent_orphaned_agent_panes_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="prevent_orphaned_agent_panes" name="Prevent orphaned agent panes" isExecutable="false">
    <bpmn:startEvent id="start" name="Pane lifecycle aligned">
      <bpmn:documentation>Begin from the operator-aligned delegate cleanup and OpenWiki placeholder-reuse rules. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:38-48</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="38-48" />
      </bpmn:extensionElements>
      <bpmn:outgoing>flow_start_approve</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="approve_plan" name="Approve pane lifecycle plan">
      <bpmn:documentation>The operator reviews the final rendered plan before guidance changes begin. Evidence: skills/bpmn-plans/SKILL.md:73-90</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="73-90" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_start_approve</bpmn:incoming>
      <bpmn:outgoing>flow_approve_gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="plan_approved" name="Plan approved?">
      <bpmn:documentation>Proceed only after the operator confirms the scope and execution flow. Evidence: skills/grilling/SKILL.md:19-25</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/grilling/SKILL.md" lines="19-25" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_approve_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_plan_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_plan_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="return_alignment" name="Return to alignment">
      <bpmn:documentation>A rejected or materially changed plan returns to alignment without implementation. Evidence: skills/grilling/SKILL.md:22-25</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/grilling/SKILL.md" lines="22-25" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_plan_no</bpmn:incoming>
      <bpmn:errorEventDefinition />
    </bpmn:endEvent>
    <bpmn:serviceTask id="assign_cleanup_owner" name="Assign temporary pane cleanup">
      <bpmn:documentation>Make the spawning agent retain and close each temporary delegate pane after its result and required follow-up. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:43-43</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="43-43" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_plan_yes</bpmn:incoming>
      <bpmn:outgoing>flow_owner_terminal</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="close_terminal_delegates" name="Close terminal review and research panes">
      <bpmn:documentation>Add concise terminal cleanup to review and research without interrupting retry, context-gap, or exact-delta follow-up. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:44-44</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="44-44" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_owner_terminal</bpmn:incoming>
      <bpmn:outgoing>flow_terminal_retention</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="reconcile_retention" name="Reconcile retained work panes">
      <bpmn:documentation>Preserve accountable and operator-created panes while excluding completed temporary delegates from terminal retention. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:45-45</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="45-45" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_terminal_retention</bpmn:incoming>
      <bpmn:outgoing>flow_retention_placeholder</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="reuse_openwiki_placeholder" name="Start maintainer in placeholder">
      <bpmn:documentation>Run Codex in the returned worktree pane, verify detection, and assign the stable maintainer name without creating a split. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:47-48</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="47-48" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_retention_placeholder</bpmn:incoming>
      <bpmn:outgoing>flow_placeholder_checks</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_entry" name="Run or rerun focused checks">
      <bpmn:documentation>Join the initial and repaired paths before the same focused validation. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:46-46</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="46-46" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_placeholder_checks</bpmn:incoming>
      <bpmn:incoming>flow_repair_checks</bpmn:incoming>
      <bpmn:outgoing>flow_checks_validate</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="validate_guidance" name="Validate guidance and activation">
      <bpmn:documentation>Validate changed Skills, concise policy consistency, activation regressions, and diff hygiene. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:46-46</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="46-46" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_validate</bpmn:incoming>
      <bpmn:outgoing>flow_validate_exercise</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="exercise_cleanup" name="Exercise live pane lifecycles">
      <bpmn:documentation>Verify disposable delegate cleanup, placeholder-based Codex startup, and removal of the known empty OpenWiki pane without disturbing maintainers or operator panes. Evidence: backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md:43-48</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-25 - Prevent-orphaned-agent-panes.md" lines="43-48" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_validate_exercise</bpmn:incoming>
      <bpmn:outgoing>flow_exercise_gateway</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="checks_green" name="Focused checks green?">
      <bpmn:documentation>Repair only in-scope failures and rerun the focused checks until green. Evidence: AGENTS.md:13-17</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="AGENTS.md" lines="13-17" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_exercise_gateway</bpmn:incoming>
      <bpmn:outgoing>flow_checks_yes</bpmn:outgoing>
      <bpmn:outgoing>flow_checks_no</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="repair" name="Repair in-scope failures">
      <bpmn:documentation>Apply the smallest causal correction inside the approved responsibility boundary. Evidence: AGENTS.md:13-17</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="AGENTS.md" lines="13-17" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_no</bpmn:incoming>
      <bpmn:outgoing>flow_repair_checks</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:callActivity id="complete_delivery" name="Complete qq Change delivery" calledElement="qq_change_delivery">
      <bpmn:documentation>Invoke the inherited reviewed, checked, finalized, one-PR delivery procedure. Evidence: skills/bpmn-plans/SKILL.md:24-42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="24-42" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_checks_yes</bpmn:incoming>
      <bpmn:outgoing>flow_delivery_green</bpmn:outgoing>
    </bpmn:callActivity>
    <bpmn:endEvent id="green_pr" name="Green PR ready">
      <bpmn:documentation>End when the approved change is green and ready for operator disposition. Evidence: skills/bpmn-plans/SKILL.md:34-42</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="34-42" />
      </bpmn:extensionElements>
      <bpmn:incoming>flow_delivery_green</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="flow_start_approve" sourceRef="start" targetRef="approve_plan" />
    <bpmn:sequenceFlow id="flow_approve_gateway" sourceRef="approve_plan" targetRef="plan_approved" />
    <bpmn:sequenceFlow id="flow_plan_yes" name="yes" sourceRef="plan_approved" targetRef="assign_cleanup_owner" />
    <bpmn:sequenceFlow id="flow_plan_no" name="no" sourceRef="plan_approved" targetRef="return_alignment" />
    <bpmn:sequenceFlow id="flow_owner_terminal" sourceRef="assign_cleanup_owner" targetRef="close_terminal_delegates" />
    <bpmn:sequenceFlow id="flow_terminal_retention" sourceRef="close_terminal_delegates" targetRef="reconcile_retention" />
    <bpmn:sequenceFlow id="flow_retention_placeholder" sourceRef="reconcile_retention" targetRef="reuse_openwiki_placeholder" />
    <bpmn:sequenceFlow id="flow_placeholder_checks" sourceRef="reuse_openwiki_placeholder" targetRef="checks_entry" />
    <bpmn:sequenceFlow id="flow_checks_validate" sourceRef="checks_entry" targetRef="validate_guidance" />
    <bpmn:sequenceFlow id="flow_validate_exercise" sourceRef="validate_guidance" targetRef="exercise_cleanup" />
    <bpmn:sequenceFlow id="flow_exercise_gateway" sourceRef="exercise_cleanup" targetRef="checks_green" />
    <bpmn:sequenceFlow id="flow_checks_yes" name="yes" sourceRef="checks_green" targetRef="complete_delivery" />
    <bpmn:sequenceFlow id="flow_checks_no" name="no" sourceRef="checks_green" targetRef="repair" />
    <bpmn:sequenceFlow id="flow_repair_checks" sourceRef="repair" targetRef="checks_entry" />
    <bpmn:sequenceFlow id="flow_delivery_green" sourceRef="complete_delivery" targetRef="green_pr" />
  </bpmn:process>
</bpmn:definitions>
