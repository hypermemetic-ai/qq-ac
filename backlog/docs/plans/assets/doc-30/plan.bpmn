<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:qq="http://qq.local/schema/evidence" id="bound_openwiki_corrections_definitions" targetNamespace="http://qq.local/schema/bpmn">
  <bpmn:process id="bound_openwiki_corrections" name="Bound OpenWiki correction retries" isExecutable="false">
    <bpmn:startEvent id="intent_aligned" name="Bounded repair approved">
      <bpmn:documentation>Begin from the operator-approved boundary: proportional diagram rejection, one correction retry, and preserved authorship and single-writer semantics. Evidence: backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md:22-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md" lines="22-32" />
      </bpmn:extensionElements>
      <bpmn:outgoing>f01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="rewrite_maintainer_policy" name="Bound maintainer recovery">
      <bpmn:documentation>Replace the all-or-nothing diagram failure rule with mechanical bundle rejection, a one-retry ceiling, and an evidence-preserving stop while retaining reset behavior for incomplete runs and newer main. Evidence: backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md:28-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md" lines="28-32" />
      </bpmn:extensionElements>
      <bpmn:incoming>f01</bpmn:incoming>
      <bpmn:outgoing>f02</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="revise_generator_guidance" name="Ground diagram acceptance">
      <bpmn:documentation>Make the generator trace semantic flow targets and judge actual embed readability with linked full resolution; aspect ratio alone is not a failure. Evidence: bin/qq-openwiki:158-168</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="bin/qq-openwiki" lines="158-168" />
      </bpmn:extensionElements>
      <bpmn:incoming>f02</bpmn:incoming>
      <bpmn:outgoing>f03</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="update_focused_checks" name="Update focused checks">
      <bpmn:documentation>Update wrapper assertions and validate the edited Skill so the intended prompt and methodology contract are observed mechanically where possible. Evidence: tests/test-qq-openwiki.sh:89-105</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="tests/test-qq-openwiki.sh" lines="89-105" />
      </bpmn:extensionElements>
      <bpmn:incoming>f03</bpmn:incoming>
      <bpmn:outgoing>f04</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="run_local_checks" name="Run local checks">
      <bpmn:documentation>Run focused wrapper tests, shell syntax and lint, Skill validation, plan generation checks, and git diff checks. Evidence: backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md:28-32</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md" lines="28-32" />
      </bpmn:extensionElements>
      <bpmn:incoming>f04</bpmn:incoming>
      <bpmn:incoming>f07</bpmn:incoming>
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:incoming>f17</bpmn:incoming>
      <bpmn:outgoing>f05</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="local_checks_green" name="Local checks green?">
      <bpmn:documentation>Decide whether every applicable local Check passes against the intended Change. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
      <bpmn:incoming>f05</bpmn:incoming>
      <bpmn:outgoing>f06</bpmn:outgoing>
      <bpmn:outgoing>f08</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_local_failures" name="Fix in-scope failures">
      <bpmn:documentation>Correct only failures caused by the agreed Change and rerun the affected local Checks. Evidence: skills/deliver-change/SKILL.md:28-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="28-36" />
      </bpmn:extensionElements>
      <bpmn:incoming>f06</bpmn:incoming>
      <bpmn:outgoing>f07</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="fresh_context_review" name="Independent review">
      <bpmn:documentation>Give the exact verified working-tree delta to one fresh read-only reviewer for material correctness, intent, reliability, and standards findings. Evidence: skills/code-review/SKILL.md:44-68</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="44-68" />
      </bpmn:extensionElements>
      <bpmn:incoming>f08</bpmn:incoming>
      <bpmn:outgoing>f09</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="confirmed_findings" name="Confirmed findings?">
      <bpmn:documentation>Verify reviewer findings against the Repository and decide whether any confirmed in-scope finding remains. Evidence: skills/code-review/SKILL.md:70-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>f09</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_review_findings" name="Fix confirmed findings">
      <bpmn:documentation>Apply the smallest causal correction for each confirmed in-scope finding, rerun affected Checks, and send the exact delta back through review. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="commit_green_change" name="Commit green change">
      <bpmn:documentation>Commit only the reviewed, locally green Task, policy, prompt, test, and plan artifacts. Evidence: skills/deliver-change/SKILL.md:34-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="34-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="open_pull_request" name="Push and open PR">
      <bpmn:documentation>Push the green commit and open one pull request carrying Task intent and Check evidence. Evidence: skills/deliver-change/SKILL.md:37-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="run_github_checks" name="Run GitHub checks">
      <bpmn:documentation>Observe all applicable final GitHub-side Checks on the pull request. Evidence: skills/deliver-change/SKILL.md:37-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-39" />
      </bpmn:extensionElements>
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="pull_request_green" name="Pull request green?">
      <bpmn:documentation>Decide whether the pull request is open, mergeable, unmerged, and all applicable Checks are green. Evidence: skills/deliver-change/SKILL.md:54-58</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="54-58" />
      </bpmn:extensionElements>
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="fix_pr_failures" name="Fix PR failures">
      <bpmn:documentation>Correct an in-scope pull-request failure in the same Change, then repeat local verification and independent review. Evidence: skills/deliver-change/SKILL.md:46-52</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="46-52" />
      </bpmn:extensionElements>
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="green_handoff" name="Green PR ready">
      <bpmn:documentation>End planned execution with the bounded-retry Change green in its pull request and ready for finalization and operator handoff. Evidence: skills/bpmn-plans/SKILL.md:25-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="25-31" />
      </bpmn:extensionElements>
      <bpmn:incoming>f18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f01" sourceRef="intent_aligned" targetRef="rewrite_maintainer_policy">
      <bpmn:documentation>The approved outcome first changes the policy that creates the destructive loop. Evidence: backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md:23-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md" lines="23-31" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f02" sourceRef="rewrite_maintainer_policy" targetRef="revise_generator_guidance">
      <bpmn:documentation>Align internal generation guidance with the maintainer's material acceptance boundary. Evidence: backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md:28-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="backlog/tasks/task-21 - Bound-OpenWiki-correction-retries-and-reject-defective-diagram-bundles.md" lines="28-31" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f03" sourceRef="revise_generator_guidance" targetRef="update_focused_checks">
      <bpmn:documentation>Changed wrapper guidance requires focused regression assertions. Evidence: tests/test-qq-openwiki.sh:89-103</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="tests/test-qq-openwiki.sh" lines="89-103" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f04" sourceRef="update_focused_checks" targetRef="run_local_checks">
      <bpmn:documentation>Execute the Checks after the coherent implementation and regression-test slice is complete. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f05" sourceRef="run_local_checks" targetRef="local_checks_green">
      <bpmn:documentation>Evaluate the fresh local Check results. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f06" name="no" sourceRef="local_checks_green" targetRef="fix_local_failures">
      <bpmn:documentation>A local failure returns to the smallest in-scope correction. Evidence: skills/deliver-change/SKILL.md:28-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="28-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f07" sourceRef="fix_local_failures" targetRef="run_local_checks">
      <bpmn:documentation>Rerun every Check affected by the correction. Evidence: skills/deliver-change/SKILL.md:30-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f08" name="yes" sourceRef="local_checks_green" targetRef="fresh_context_review">
      <bpmn:documentation>A locally green non-trivial Change proceeds to mandatory independent review before commit or publication. Evidence: skills/deliver-change/SKILL.md:34-36</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="34-36" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f09" sourceRef="fresh_context_review" targetRef="confirmed_findings">
      <bpmn:documentation>The owning agent verifies the reviewer's returned findings against Repository evidence. Evidence: skills/code-review/SKILL.md:70-77</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="70-77" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f10" name="yes" sourceRef="confirmed_findings" targetRef="fix_review_findings">
      <bpmn:documentation>Confirmed in-scope findings receive the smallest causal correction. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f11" sourceRef="fix_review_findings" targetRef="run_local_checks">
      <bpmn:documentation>A review fix returns through affected Checks and fresh exact-delta review before commit. Evidence: skills/code-review/SKILL.md:78-84</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/code-review/SKILL.md" lines="78-84" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f12" name="no" sourceRef="confirmed_findings" targetRef="commit_green_change">
      <bpmn:documentation>Only a reviewed Change with no confirmed findings may be committed. Evidence: skills/deliver-change/SKILL.md:34-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="34-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f13" sourceRef="commit_green_change" targetRef="open_pull_request">
      <bpmn:documentation>Push the green commit and create its one pull request. Evidence: skills/deliver-change/SKILL.md:37-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f14" sourceRef="open_pull_request" targetRef="run_github_checks">
      <bpmn:documentation>The published Change must pass applicable GitHub-side Checks. Evidence: skills/deliver-change/SKILL.md:37-39</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="37-39" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f15" sourceRef="run_github_checks" targetRef="pull_request_green">
      <bpmn:documentation>Evaluate final pull-request state and Check results. Evidence: skills/deliver-change/SKILL.md:54-58</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="54-58" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f16" name="no" sourceRef="pull_request_green" targetRef="fix_pr_failures">
      <bpmn:documentation>An in-scope pull-request failure remains work in the same Change. Evidence: skills/deliver-change/SKILL.md:46-52</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="46-52" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f17" sourceRef="fix_pr_failures" targetRef="run_local_checks">
      <bpmn:documentation>A PR-side correction returns through local verification and independent review before republishing. Evidence: skills/deliver-change/SKILL.md:30-39,46-52</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/deliver-change/SKILL.md" lines="30-39,46-52" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="f18" name="yes" sourceRef="pull_request_green" targetRef="green_handoff">
      <bpmn:documentation>A green, open, unmerged pull request reaches the plan boundary for finalization and operator handoff. Evidence: skills/bpmn-plans/SKILL.md:25-31</bpmn:documentation>
      <bpmn:extensionElements>
        <qq:evidence file="skills/bpmn-plans/SKILL.md" lines="25-31" />
      </bpmn:extensionElements>
    </bpmn:sequenceFlow>
  </bpmn:process>
</bpmn:definitions>
